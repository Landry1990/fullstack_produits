# ═══════════════════════════════════════════════════════
# Configuration Docker - Fullstack Produits
# Copier ce fichier en .env et adapter les valeurs
# ═══════════════════════════════════════════════════════

# ── Django ──────────────────────────────────────────────
DJANGO_SECRET_KEY=changez-moi-avec-une-cle-aleatoire-de-50-caracteres
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,frontend

# ── Base de données PostgreSQL ───────────────────────────
DB_NAME=fullstack_db
DB_USER=fullstack_user
DB_PASSWORD=fullstack_password

# ── CORS / Sécurité ────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost,http://frontend
CSRF_TRUSTED_ORIGINS=http://localhost,http://frontend

# ── Fournisseur (Import auto données produits) ───────────
# Décommentez et choisissez le fournisseur à importer au démarrage:
# SUPPLIER_DATA=FOURNISSEUR1
# SUPPLIER_DATA=FOURNISSEUR2

# ── Redis ───────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Ngrok (accès externe) ────────────────────────────────
# NGROK_AUTHTOKEN=votre_token_ngrok

# ── Tailscale Funnel (accès externe sécurisé) ────────────
# Générer une auth key sur https://login.tailscale.com/admin/settings/keys
# Cocher : Reusable + Ephemeral (ou non-ephemeral pour persistance)
# TAILSCALE_AUTHKEY=tskey-auth-xxxxxxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Nom du hostname sur votre tailnet (sera accessible via https://<nom>.ts.net)
# TAILSCALE_HOSTNAME=fullstack-app

# ── Gunicorn ─────────────────────────────────────────────
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120
