# ═══════════════════════════════════════════════════════
# Zenith Pharma — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ═══════════════════════════════════════════════════════

# ── Django ──────────────────────────────────────────────
DJANGO_SECRET_KEY=changez-moi-avec-une-cle-aleatoire-de-50-caracteres
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.X,NOM_PC

# ── Base de données PostgreSQL ───────────────────────────
DB_ENGINE=django.db.backends.postgresql
DB_NAME=zenith_db
DB_USER=postgres
DB_PASSWORD=mot_de_passe_fort
DB_HOST=localhost
DB_PORT=5432

# ── Redis (OBLIGATOIRE pour 12-15 postes) ────────────────
# Installation : sudo apt install redis-server  (Linux)
#              : docker run -d -p 6379:6379 redis:alpine  (Docker)
REDIS_URL=redis://127.0.0.1:6379/1

# ── Gunicorn ─────────────────────────────────────────────
# Sur 4 cœurs → 9 workers | Sur 6 cœurs → 13 workers
GUNICORN_WORKERS=9
GUNICORN_THREADS=4
GUNICORN_BIND=0.0.0.0:8000
GUNICORN_TIMEOUT=60
GUNICORN_LOG_LEVEL=warning

# ── CORS / CSRF ──────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://192.168.1.X:3000,http://NOM_PC:3000
CSRF_TRUSTED_ORIGINS=http://192.168.1.X:3000,http://NOM_PC:3000

# ── Throttling API ───────────────────────────────────────
DJANGO_THROTTLE_ANON=100/day
DJANGO_THROTTLE_USER=500000/day
DJANGO_THROTTLE_AUTH=10/min

# ── Sentry (optionnel) ───────────────────────────────────
# SENTRY_DSN=https://xxx@sentry.io/xxx

# ── Email (obligatoire pour les notifications feedback) ──
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=votre-email@gmail.com
# Pour Gmail : utiliser un MOT DE PASSE D'APPLICATION (pas le mot de passe normal)
# https://myaccount.google.com/apppasswords
EMAIL_HOST_PASSWORD=votre-app-password-16-caracteres
DEFAULT_FROM_EMAIL=Zenith Pharma <votre-email@gmail.com>
FEEDBACK_EMAIL=admin@pharma.com

# ── Sécurité HTTPS (production avec reverse proxy) ───────
# DJANGO_SECURE_HSTS_SECONDS=31536000
