etRanking] = useState<RankingResponse | null>(null);\r\n  const [evolutionData, setEvolutionData] = useState<EvolutionSeries[]>([]);\r\n  const [selectedVendeur, setSelectedVendeur] = useState<number | null>(null);\r\n  const [periode, setPeriode] = useState<'mois' | 'trimestre' | 'annee'>('mois');\r\n  const [mois, setMois] = useState(() => {\r\n    const now = new Date();\r\n    return `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}`;\r\n  });\r\n\r\n  // Fetch ranking data\r\n  useEffect(() => {\r\n    const fetchRanking = async () => {\r\n      // Basic validation for YYYY-MM format\r\n      if (!mois || !/^\\d{4}-\\d{2}$/.test(mois)) {\r\n        console.warn(\"Format mois invalide:\", mois);\r\n        return;\r\n      }\r\n\r\n      setLoading(true);\r\n      try {\r\n        const res = await axios.get<RankingResponse>(`${apiBaseUrl}/rapports/classement_vendeurs_mensuel/`, {\r\n          params: { mois, periode }\r\n        });\r\n        setRanking(res.data);\r\n        \r\n        // Auto-select first vendeur for evolution chart\r\n        if (res.data.data.length > 0 && !selectedVendeur) {\r\n          setSelectedVendeur(res.data.data[0].vendeur_id);\r\n        }\r\n      } catch (err) {\r\n        toast.error(t('common.error', 'Erreur lors du chargement'));\r\n        console.error(err);\r\n      } finally {\r\n        setLoading(false);\r\n      }\r\n    };\r\n    fetchRanking();\r\n  }, [mois, periode]);\r\n\r\n  // Fetch global evolution data\r\n  useEffect(() => {\r\n    const fetchEvolution = async () => {\r\n      try {\r\n        const res = await axios.get<EvolutionSeries[]>(`${apiBaseUrl}/rapports/evolution_vendeur/`, {\r\n          params: { vendeur_id: 'all' }\r\n        });\r\n        setEvolutionData(res.data);\r\n      } catch (err) {\r\n        console.error(err);\r\n      }\r\n    };\r\n    fetchEvolution();\r\n  }, []);\r\n\r\n  // Format data for Recharts (merge series by month)\r\n  const chartData = evolutionData.length > 0 ? evolutionData[0].data.map((point, index) => {\r\n    const mergedPoint: any = { label: point.label };\r\n    evolutionData.forEach(series => {\r\n        mergedPoint[series.vendeur] = series.data[index]?.chiffre_affaires || 0;\r\n    });\r\n    return mergedPoint;\r\n  }) : [];\r\n\r\n  // Get medal icon\r\n  const getMedal = (rang: number) => {\r\n    switch (rang) {\r\n      case 1: return '­ƒÑç';\r\n      case 2: return '­ƒÑê';\r\n      case 3: return '­ƒÑë';\r\n      default: return rang;\r\n    }\r\n  };\r\n\r\n  return (\r\n    <div className=\"p-6 space-y-6\">\r\n      {/* Header */}\r\n      <div className=\"flex flex-col md:flex-row md:items-center md:justify-between gap-4\">\r\n        <div>\r\n          <h1 className=\"text-2xl font-bold text-base-content flex items-center gap-2\">\r\n            ­ƒÅå {t('sellers.ranking.title', 'Classement Vendeurs')}\r\n          </h1>\r\n          <p className=\"text-base-content/60\">\r\n            {t('sellers.ranking.subtitle', 'Performances mensuelles et ├®volution')}\r\n          </p>\r\n        </div>\r\n        <div className=\"flex gap-2\">\r\n          <input\r\n            type=\"month\"\r\n            className=\"input input-bordered input-sm\"\r\n            value={mois}\r\n            onChange={(e) => setMois(e.target.value)}\r\n          />\r\n          <select\r\n            className=\"select select-bordered select-sm\"\r\n            value={periode}\r\n            onChange={(e) => setPeriode(e.target.value as 'mois' | 'trimestre' | 'annee')}\r\n          >\r\n            <option value=\"mois\">{t('sellers.ranking.period.month', 'Mois')}</option>\r\n            <option value=\"trimestre\">{t('sellers.ranking.period.quarter', 'Trimestre')}</option>\r\n            <option value=\"annee\">{t('sellers.ranking.period.year', 'Ann├®e')}</option>\r\n          </select>\r\n        </div>\r\n      </div>\r\n\r\n      {/* Stats Cards */}\r\n      {ranking && ranking.data.length > 0 && (\r\n        <div className=\"grid grid-cols-1 md:grid-cols-3 gap-4\">\r\n          {ranking.data.slice(0, 3).map((v, i) => (\r\n            <div \r\n              key={v.vendeur_id}\r\n              className={`card shadow-lg cursor-pointer hover:shadow-xl transition-shadow ${\r\n                i === 0 ? 'bg-gradient-to-br from-yellow-400 to-yellow-600 text-white' :\r\n                i === 1 ? 'bg-gradient-to-br from-gray-300 to-gray-500 text-white' :\r\n                'bg-gradient-to-br from-orange-400 to-orange-600 text-white'\r\n              }`}\r\n              onClick={() => setSelectedVendeur(v.vendeur_id)}\r\n            >\r\n              <div className=\"card-body p-4\">\r\n                <div className=\"flex justify-between items-start\">\r\n                  <div>\r\n                    <p className=\"text-4xl font-bold\">{getMedal(v.rang)}</p>\r\n                    <h3 className=\"text-lg font-semibold mt-2\">{v.vendeur}</h3>\r\n                  </div>\r\n                  {v.evolution !== null && v.evolution !== undefined && (\r\n                    <div className={`badge ${v.evolution >= 0 ? 'badge-success' : 'badge-error'}`}>\r\n                      {v.evolution >= 0 ? '+' : ''}{v.evolution}%\r\n                    </div>\r\n                  )}\r\n                </div>\r\n                <div className=\"mt-4 space-y-1\">\r\n                  <p className=\"text-2xl font-bold\">{formatMoney(v.chiffre_affaires)}</p>\r\n                  <p className=\"text-sm opacity-80\">\r\n                    {v.nbre_ventes} ventes ┬À Panier: {formatMoney(v.panier_moyen)}\r\n                  </p>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          ))}\r\n        </div>\r\n      )}\r\n\r\n      {/* Main Content */}\r\n      <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-6\">\r\n        {/* Ranking Table */}\r\n        <div className=\"card bg-base-100 shadow-lg\">\r\n          <div className=\"card-body\">\r\n            <h3 className=\"text-lg font-semibold mb-4\">\r\n              {t('sellers.ranking.table_title', 'Classement Complet')}\r\n            </h3>\r\n            {loading ? (\r\n              <div className=\"h-64 flex items-center justify-center\">\r\n                <span className=\"loading loading-spinner loading-lg\"></span>\r\n              </div>\r\n            ) : ranking && ranking.data.length > 0 ? (\r\n              <div className=\"overflow-x-auto max-h-96\">\r\n                <table className=\"table table-sm table-zebra\">\r\n                  <thead className=\"sticky top-0 bg-base-100\">\r\n                    <tr>\r\n                      <th>#</th>\r\n                      <th>{t('sellers.ranking.seller', 'Vendeur')}</th>\r\n                      <th className=\"text-right\">{t('sellers.ranking.sales', 'Ventes')}</th>\r\n                      <th className=\"text-right\">{t('sellers.ranking.revenue', 'CA')}</th>\r\n                      <th className=\"text-right\">{t('sellers.ranking.avg_basket', 'Panier')}</th>\r\n                      <th className=\"text-right\">{t('sellers.ranking.evolution', '├ëvol.')}</th>\r\n                    </tr>\r\n                  </thead>\r\n                  <tbody>\r\n                    {ranking.data.map((v) => (\r\n                      <tr \r\n                        key={v.vendeur_id}\r\n                        className={`cursor-pointer hover:bg-base-200 ${selectedVendeur === v.vendeur_id ? 'bg-primary/10' : ''}`}\r\n                        onClick={() => setSelectedVendeur(v.vendeur_id)}\r\n                      >\r\n                        <td className=\"font-bold\">{getMedal(v.rang)}</td>\r\n                        <td>{v.vendeur}</td>\r\n                        <td className=\"text-right\">{v.nbre_ventes}</td>\r\n                        <td className=\"text-right font-mono\">{formatMoney(v.chiffre_affaires)}</td>\r\n                        <td className=\"text-right font-mono text-sm\">{formatMoney(v.panier_moyen)}</td>\r\n                        <td className=\"text-right\">\r\n                          {v.evolution !== null && v.evolution !== undefined ? (\r\n                            <span className={v.evolution >= 0 ? 'text-success' : 'text-error'}>\r\n                              {v.evolution >= 0 ? '+' : ''}{v.evolution}%\r\n                            </span>\r\n                          ) : '-'}\r\n                        </td>\r\n                      </tr>\r\n                    ))}\r\n                  </tbody>\r\n                </table>\r\n              </div>\r\n            ) : (\r\n              <div className=\"h-64 flex items-center justify-center text-base-content/50\">\r\n                {t('sellers.ranking.no_data', 'Aucune donn├®e pour cette p├®riode')}\r\n              </div>\r\n            )}\r\n          </div>\r\n        </div>\r\n\r\n        {/* Evolution Chart */}\r\n        <div className=\"card bg-base-100 shadow-lg\">\r\n          <div className=\"card-body\">\r\n            <h3 className=\"text-lg font-semibold mb-4\">\r\n              {t('sellers.ranking.evolution_chart', '├ëvolution (12 mois)')}\r\n            </h3>\r\n            {chartData.length > 0 ? (\r\n              <ResponsiveContainer width=\"100%\" height={350}>\r\n                <LineChart data={chartData}>\r\n                  <CartesianGrid strokeDasharray=\"3 3\" opacity={0.3} />\r\n                  <XAxis dataKey=\"label\" fontSize={11} />\r\n                  <YAxis tickFormatter={(v) => `${(v / 1000).toFixed(0)}k`} fontSize={11} />\r\n                  <Tooltip formatter={(value: number) => formatMoney(value)} />\r\n                  <Legend />\r\n                  {evolutionData.map((series, index) => (\r\n                    <Line \r\n                        key={series.vendeur_id}\r\n                        type=\"monotone\" \r\n                        dataKey={series.vendeur} \r\n                        name={series.vendeur} \r\n                        stroke={COLORS[index % COLORS.length]} \r\n                        strokeWidth={2}\r\n                        dot={false}\r\n                        opacity={selectedVendeur === null || selectedVendeur === series.vendeur_id ? 1 : 0.2}\r\n                    />\r\n                  ))}\r\n                </LineChart>\r\n              </ResponsiveContainer>\r\n            ) : (\r\n              <div className=\"h-80 flex items-center justify-center text-base-content/50\">\r\n                {t('common.loading', 'Chargement...')}\r\n              </div>\r\n            )}\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      {/* Bar Chart Comparison (Top 5) */}\r\n      {ranking && ranking.data.length > 0 && (\r\n        <div className=\"card bg-base-100 shadow-lg\">\r\n          <div className=\"card-body\">\r\n            <h3 className=\"text-lg font-semibold mb-4\">\r\n              {t('sellers.ranking.comparison', 'Comparaison CA')}\r\n            </h3>\r\n            <ResponsiveContainer width=\"100%\" height={300}>\r\n              <BarChart data={ranking.data.slice(0, 5)} layout=\"vertical\">\r\n                <CartesianGrid strokeDasharray=\"3 3\" opacity={0.3} />\r\n                <XAxis type=\"number\" tickFormatter={(v) => `${(v / 1000).toFixed(0)}k`} />\r\n                <YAxis type=\"category\" dataKey=\"vendeur\" width={100} fontSize={12} />\r\n                <Tooltip formatter={(value: number) => formatMoney(value)} />\r\n                <Bar dataKey=\"chiffre_affaires\" name=\"CA\" radius={[0, 4, 4, 0]}>\r\n                  {ranking.data.slice(0, 5).map((_, index) => (\r\n                    <Bar key={index} dataKey=\"chiffre_affaires\" fill={COLORS[index % COLORS.length]} />\r\n                  ))}\r\n                </Bar>\r\n              </BarChart>\r\n            </ResponsiveContainer>\r\n          </div>\r\n        </div>\r\n      )}\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Projet Fullstack\\fullstack_produits\\frontend\\frontend\\src\\components\\Clients.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":71,"column":58,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":71,"endColumn":61,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[2352,2355],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[2352,2355],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/ban-ts-comment","severity":2,"message":"Use \"@ts-expect-error\" instead of \"@ts-ignore\", as \"@ts-ignore\" will do nothing if the following line is error-free.","line":89,"column":9,"nodeType":"Line","messageId":"tsIgnoreInsteadOfExpectError","endLine":89,"endColumn":58,"suggestions":[{"messageId":"replaceTsIgnoreWithTsExpectError","fix":{"range":[2851,2900],"text":"// @ts-expect-error - Backend supports include_inactive"},"desc":"Replace \"@ts-ignore\" with \"@ts-expect-error\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'err' is defined but never used.","line":100,"column":14,"nodeType":null,"messageId":"unusedVar","endLine":100,"endColumn":17},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'fetchClients'. Either include it or remove the dependency array.","line":109,"column":6,"nodeType":"ArrayExpression","endLine":109,"endColumn":50,"suggestions":[{"desc":"Update the dependencies array to be: [showInactive, currentPage, debouncedSearch, fetchClients]","fix":{"range":[3342,3386],"text":"[showInactive, currentPage, debouncedSearch, fetchClients]"}}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":149,"