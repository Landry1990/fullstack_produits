xl shadow-sm border border-base-200 overflow-hidden\">\r\n            <div className=\"bg-base-100 px-6 py-4 border-b border-base-200\">\r\n              <h2 className=\"font-semibold text-lg flex items-center gap-2\">\r\n                <svg xmlns=\"http://www.w3.org/2000/svg\" className=\"h-5 w-5 text-primary\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\r\n                  <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth=\"2\" d=\"M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z\" />\r\n                  <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth=\"2\" d=\"M15 11a3 3 0 11-6 0 3 3 0 016 0z\" />\r\n                </svg>\r\n                Coordonn├®es\r\n              </h2>\r\n            </div>\r\n            <div className=\"p-6 space-y-4\">\r\n              <div className=\"form-control\">\r\n                <label className=\"label\">\r\n                  <span className=\"label-text font-medium\">Adresse</span>\r\n                </label>\r\n                <input\r\n                  type=\"text\"\r\n                  value={formData.address || ''}\r\n                  onChange={(e) => handleChange('address', e.target.value)}\r\n                  className=\"input input-bordered w-full\"\r\n                  placeholder=\"123 Avenue de la R├®publique\"\r\n                />\r\n              </div>\r\n\r\n              <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\r\n                <div className=\"form-control\">\r\n                  <label className=\"label\">\r\n                    <span className=\"label-text font-medium\">Ville</span>\r\n                  </label>\r\n                  <input\r\n                    type=\"text\"\r\n                    value={formData.city || ''}\r\n                    onChange={(e) => handleChange('city', e.target.value)}\r\n                    className=\"input input-bordered w-full\"\r\n                    placeholder=\"Douala\"\r\n                  />\r\n                </div>\r\n                <div className=\"form-control\">\r\n                  <label className=\"label\">\r\n                    <span className=\"label-text font-medium\">Pays</span>\r\n                  </label>\r\n                  <input\r\n                    type=\"text\"\r\n                    value={formData.country || ''}\r\n                    onChange={(e) => handleChange('country', e.target.value)}\r\n                    className=\"input input-bordered w-full\"\r\n                    placeholder=\"Cameroun\"\r\n                  />\r\n                </div>\r\n              </div>\r\n\r\n              <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\r\n                <div className=\"form-control\">\r\n                  <label className=\"label\">\r\n                    <span className=\"label-text font-medium\">T├®l├®phone</span>\r\n                  </label>\r\n                  <input\r\n                    type=\"tel\"\r\n                    value={formData.phone || ''}\r\n                    onChange={(e) => handleChange('phone', e.target.value)}\r\n                    className=\"input input-bordered w-full\"\r\n                    placeholder=\"+237 6XX XXX XXX\"\r\n                  />\r\n                </div>\r\n                <div className=\"form-control\">\r\n                  <label className=\"label\">\r\n                    <span className=\"label-text font-medium\">Email</span>\r\n                  </label>\r\n                  <input\r\n                    type=\"email\"\r\n                    value={formData.email || ''}\r\n                    onChange={(e) => handleChange('email', e.target.value)}\r\n                    className=\"input input-bordered w-full\"\r\n                    placeholder=\"contact@pharmacie.com\"\r\n                  />\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n\r\n          {/* Section: