s = async () => {\r\n        setLoading(true);\r\n        setError(null);\r\n        try {\r\n            const token = safeStorage.getItem('authToken');\r\n            const apiBaseUrl = import.meta.env.VITE_API_BASE_URL || '/api';\r\n            \r\n            // Format to YYYY-MM-DDTHH:MM\r\n            const dateDebut = `${dateDebutStr}T${startTime}`;\r\n            const dateFin = `${dateFinStr}T${endTime}`;\r\n\r\n            const response = await axios.get(`${apiBaseUrl}/factures/caisse_par_tranche_horaire/`, {\r\n                params: { date_debut: dateDebut, date_fin: dateFin },\r\n                headers: { Authorization: `Token ${token}` }\r\n            });\r\n            onVerify?.(response.data);\r\n        } catch (err: any) {\r\n            console.error(\"Failed to fetch tranche stats\", err);\r\n            setError(err.response?.data?.detail || \"Erreur lors de la r├®cup├®ration des donn├®es\");\r\n        } finally {\r\n            setLoading(false);\r\n        }\r\n    };\r\n\r\n    return (\r\n        <div className=\"bg-base-100 rounded-2xl shadow-sm border border-base-300 p-6 space-y-4\">\r\n            <div className=\"flex items-center justify-between border-b border-base-200 pb-4\">\r\n                <div className=\"flex items-center gap-3\">\r\n                    <div className=\"p-2 bg-primary/10 rounded-lg\">\r\n                        <Clock className=\"w-5 h-5 text-primary\" />\r\n                    </div>\r\n                    <div>\r\n                        <h3 className=\"font-bold text-base-content\">\r\n                            V├®rification par Tranche Horaire\r\n                        </h3>\r\n                        <p className=\"text-xs text-base-content/60\">\r\n                            Comparez les montants de vente pour une p├®riode pr├®cise aujourd'hui\r\n                        </p>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n\r\n            <div className=\"flex flex-wrap items-end gap-4\">\r\n                <div className=\"form-control\">\r\n                    <label className=\"label py-1\">\r\n                        <span className=\"label-text text-xs font-semibold\">Heure de d├®but</span>\r\n                    </label>\r\n                    <input \r\n                        type=\"time\" \r\n                        className=\"input input-bordered input-sm\"\r\n                        value={startTime}\r\n                        onChange={(e) => setStartTime(e.target.value)}\r\n                    />\r\n                </div>\r\n                <div className=\"form-control\">\r\n                    <label className=\"label py-1\">\r\n                        <span className=\"label-text text-xs font-semibold\">Heure de fin</span>\r\n                    </label>\r\n                    <input \r\n                        type=\"time\" \r\n                        className=\"input input-bordered input-sm\"\r\n                        value={endTime}\r\n                        onChange={(e) => setEndTime(e.target.value)}\r\n                    />\r\n                </div>\r\n                <button \r\n                    className={`btn btn-primary btn-sm flex items-center gap-2 ${loading ? 'loading' : ''}`}\r\n                    onClick={fetchTrancheStats}\r\n                    disabled={loading}\r\n                >\r\n                    {!loading && <Search className=\"w-4 h-4\" />}\r\n                    V├®rifier\r\n                </button>\r\n            </div>\r\n\r\n            {error && (\r\n                <div className=\"alert alert-error py-2 text-sm\">\r\n                    {error}\r\n                </div>\r\n            )}\r\n\r\n        </div>\r\n    );\r\n};\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Projet Fullstack\\fullstack_produits\\frontend\\frontend\\src\\components\\sales\\modals\\ClientNameModal.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCou