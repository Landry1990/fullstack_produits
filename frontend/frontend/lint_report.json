\r\n              </div>\r\n            </label>\r\n            <label className=\"label cursor-pointer gap-2 border rounded-xl p-4 flex-1 hover:bg-base-200 transition-colors\">\r\n              <input\r\n                type=\"radio\"\r\n                name=\"format\"\r\n                className=\"radio radio-primary\"\r\n                checked={labelFormat === '30x15'}\r\n                onChange={() => setLabelFormat('30x15')}\r\n              />\r\n              <div className=\"flex-1\">\r\n                <span className=\"label-text font-semibold\">30mm ├ù 15mm</span>\r\n                <p className=\"text-xs text-base-content/60\">Format compact</p>\r\n              </div>\r\n            </label>\r\n          </div>\r\n        </div>\r\n\r\n        {/* Info */}\r\n        <div className=\"alert alert-info rounded-xl\">\r\n          <svg xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" viewBox=\"0 0 24 24\" className=\"stroke-current shrink-0 w-5 h-5\">\r\n            <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth=\"2\" d=\"M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z\"></path>\r\n          </svg>\r\n          <div className=\"text-sm\">\r\n            <p><strong>Contenu des ├®tiquettes:</strong></p>\r\n            <ul className=\"list-disc list-inside mt-1 text-xs\">\r\n              <li>Nom du produit</li>\r\n              <li>Code-barres (CIP1/CIP2/CIP3)</li>\r\n              <li>Num├®ro de lot</li>\r\n              <li>Fournisseur</li>\r\n              <li>Date d'entr├®e</li>\r\n              <li>Prix de vente</li>\r\n            </ul>\r\n          </div>\r\n        </div>\r\n\r\n        {/* Debug Mode */}\r\n        <div>\r\n          <label className=\"label cursor-pointer justify-start gap-3 rounded-xl border p-3\">\r\n            <input\r\n              type=\"checkbox\"\r\n              className=\"checkbox checkbox-warning checkbox-sm\"\r\n              checked={debugMode}\r\n              onChange={(e) => setDebugMode(e.target.checked)}\r\n            />\r\n            <div>\r\n              <span className=\"label-text font-semibold\">Mode Debug</span>\r\n              <p className=\"text-xs text-base-content/60\">Affiche les bordures et la grille pour tester les positions</p>\r\n            </div>\r\n          </label>\r\n        </div>\r\n\r\n        {/* Actions */}\r\n        <div className=\"flex justify-end gap-3 pt-2\">\r\n          <button onClick={onClose} className=\"btn btn-ghost px-6 rounded-xl\">\r\n            Annuler\r\n          </button>\r\n          <button\r\n            onClick={handlePrint}\r\n            className=\"btn btn-primary px-8 rounded-xl shadow-lg shadow-primary/20 gap-2\"\r\n            disabled={printing}\r\n          >\r\n            {printing ? (\r\n              <>\r\n                <span className=\"loading loading-spinner loading-sm\"></span>\r\n                G├®n├®ration en cours...\r\n              </>\r\n            ) : (\r\n              <>\r\n                <svg xmlns=\"http://www.w3.org/2000/svg\" className=\"h-4 w-4\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\r\n                  <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z\" />\r\n                </svg>\r\n                G├®n├®rer PDF\r\n              </>\r\n            )}\r\n          </button>\r\n        </div>\r\n      </div>\r\n    </PremiumModal>\r\n  )\r\n}\r\n\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Projet Fullstack\\fullstack_produits\\frontend\\frontend\\src\\components\\StatistiquesFournisseur.tsx","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'fetchStats'. Either include it or remove the dependency array.","line":91,"column":6,"nodeType":"ArrayExpression","endLine":91,"endColumn":8,"suggestions":[{"desc":"Update the dependencies array to be: [fetchStats]","fix":{"range":[2530,2532],"text":"[fetchStats]"}}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":292,"column":102,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":292,"endColumn":105,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[13751,13754],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[13751,13754],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useEffect, useMemo } from 'react';\r\nimport axios from 'axios';\r\nimport { formatCurrency } from '../utils/formatters';\r\nimport {\r\n  BarChart,\r\n  Bar,\r\n  XAxis,\r\n  YAxis,\r\n  CartesianGrid,\r\n  Tooltip,\r\n  ResponsiveContainer,\r\n  Legend,\r\n  PieChart,\r\n  Pie,\r\n  Cell\r\n} from 'recharts';\r\nimport {\r\n  useAnalyseFournisseurs,\r\n  useComparaisonPrix,\r\n  useRepartitionAchats\r\n} from '../hooks/useFinanceStats';\r\n\r\ninterface StatsFournisseur {\r\n  id: number;\r\n  nom: string;\r\n  ca_ttc: number;\r\n  cout_achat: number;\r\n  marge_brute: number;\r\n  quantite_vendue: number;\r\n}\r\n\r\nconst COLORS = [\r\n  '#0088FE', '#00C49F', '#FFBB28', '#FF8042', '#8884d8', '#82ca9d',\r\n  '#3B82F6', '#EF4444', '#10B981', '#F59E0B', '#6366F1', '#EC4899',\r\n  '#8B5CF6', '#14B8A6', '#F97316', '#06B6D4', '#84CC16', '#D946EF'\r\n];\r\n\r\nexport default function StatistiquesFournisseur() {\r\n  const [activeTab, setActiveTab] = useState('ventes');\r\n\r\n  // Helper pour formater les dates en YYYY-MM-DD local\r\n  const formatDate = (date: Date) => {\r\n    const year = date.getFullYear();\r\n    const month = String(date.getMonth() + 1).padStart(2, '0');\r\n    const day = String(date.getDate()).padStart(2, '0');\r\n    return `${year}-${month}-${day}`;\r\n  };\r\n\r\n  const [stats, setStats] = useState<StatsFournisseur[]>([]);\r\n  const [loading, setLoading] = useState(false);\r\n  const [dateDebut, setDateDebut] = useState(() => {\r\n    const d = new Date();\r\n    d.setDate(1); // 1er du mois\r\n    return formatDate(d);\r\n  });\r\n  const [dateFin, setDateFin] = useState(() => {\r\n    return formatDate(new Date());\r\n  });\r\n\r\n  // Hooks pour les nouvelles analyses\r\n  const { data: supplierAnalysis, isLoading: loadingAnalysis } = useAnalyseFournisseurs();\r\n  const { data: prixComparaison, isLoading: loadingPrix } = useComparaisonPrix();\r\n  const { data: repartitionAchats, isLoading: loadingRepartition } = useRepartitionAchats();\r\n\r\n  const apiBaseUrl = useMemo(\r\n    () => (import.meta.env.VITE_API_BASE_URL ?? '').replace(/\\/$/, ''),\r\n    [],\r\n  );\r\n\r\n  const fetchStats = async () => {\r\n    try {\r\n      setLoading(true);\r\n\r\n      const response = await axios.get(`${apiBaseUrl}/api/statistiques/ca_par_fournisseur/`, {\r\n        params: {\r\n          date_debut: dateDebut,\r\n          date_fin: dateFin\r\n        }\r\n      });\r\n\r\n      setStats(response.data);\r\n    } catch (error) {\r\n      console.error(\"Erreur lors du chargement des statistiques\", error);\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  };\r\n\r\n  useEffect(() => {\r\n    fetchStats();\r\n  }, []); \r\n\r\n  // Totaux Ventes\r\n  const totaux = useMemo(() => {\r\n    return stats.reduce((acc, curr) => ({\r\n      ca_ttc: acc.ca_ttc + Number(curr.ca_ttc),\r\n      cout_achat: acc.cout_achat + Number(curr.cout_achat),\r\n      marge_brute: acc.marge_brute + Number(curr.marge_brute),\r\n      quantite_vendue: acc.quantite_vendue + curr.quantite_vendue\r\n    }), { ca_ttc: 0, cout_achat: 0, marge_brute: 0, quantite_vendue: 0 });\r\n  }, [stats]);\r\n\r\n  return (\r\n    <div className=\"p-6 space-y-6 animate-fade-in\">\r\n      <div className=\"flex flex-col md:flex-row justify-between items-center gap-4\">\r\n        <div>\r\n          <h1 className=\"text-2xl font-bold text-base-content\">Statistiques par Fournisseur</h1>\r\n          <p className=\"text-sm text-base-content/80\">Analyse d├®taill├®e des performances achats et ventes</p>\r\n        </div>\r\n        \r\n        {/* Date Filter only for Sales Tab currently */}\r\n        {activeTab === 'ventes' && (\r\n            <div className=\"flex items-end gap-2 bg-base-100 p-2 rounded-lg shadow-sm border border-base-200\">\r\n            <div className=\"form-control\">\r\n                <label className=\"label py-1\"><span className=\"label-text text-xs\">Du</span></label>\r\n                <input \r\n                type=\"date\" \r\n                className=\"input input-bordered input-sm\" \r\n                value={dateDebut}\r\n                onChange={(e) => setDateDebut(e.target.value)}\r\n                />\r\n            </div>\r\n            <div className=\"form-control\">\r\n                <label className=\"label py-1\"><span className=\"label-text text-xs\">Au</span></label>\r\n                <input \r\n                type=\"date\" \r\n                className=\"input input-bordered input-sm\" \r\n                value={dateFin}\r\n                onChange={(e) => setDateFin(e.target.value)}\r\n                />\r\n            </div>\r\n            <button \r\n                className=\"btn btn-primary btn-sm\"\r\n                onClick={fetchStats}\r\n                disabled={loading}\r\n            >\r\n                {loading ? <span className=\"loading loading-spinner loading-xs\"></span> : 'Actualiser'}\r\n            </button>\r\n            </div>\r\n        )}\r\n      </div>\r\n\r\n      {/* Tabs Navigation */}\r\n      <div className=\"tabs tabs-boxed bg-base-100 p-1\">\r\n        <a className={`tab ${activeTab === 'ventes' ? 'tab-active' : ''}`} onClick={() => setActiveTab('ventes')}>Ventes & Marges</a>\r\n        <a className={`tab ${activeTab === 'performance' ? 'tab-active' : ''}`} onClick={() => setActiveTab('performance')}>Performance (Scoring)</a>\r\n        <a className={`tab ${activeTab === 'prix' ? 'tab-active' : ''}`} onClick={() => setActiveTab('prix')}>Comparateur Prix</a>\r\n        <a className={`tab ${activeTab === 'concentration' ? 'tab-active' : ''}`} onClick={() => setActiveTab('concentration')}>Concentration Achats</a>\r\n      </div>\r\n\r\n      {/* TAB 1: VENTES (Existing Content) */}\r\n      {activeTab === 'ventes' && (\r\n        <div className=\"space-y-6 animate-fade-in\">\r\n           {/* Info Box */}\r\n            <div className=\"alert alert-info shadow-sm\">\r\n                <svg xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" viewBox=\"0 0 24 24\" className=\"stroke-current shrink-0 w-6 h-6\">\r\n                <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth=\"2\" d=\"M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z\"></path>\r\n                </svg>\r\n                <div>\r\n                <h3 className=\"font-bold\">M├®thode de calcul : Ventes R├®alis├®es</h3>\r\n                <div className=\"text-sm\">\r\n                    Les statistiques ci-dessous concernent uniquement les produits <strong>vendus</strong> sur la p├®riode s├®lectionn├®e (CA encaiss├®).\r\n                </div>\r\n                </div>\r\n            </div>\r\n\r\n            {/* Cartes R├®sum├® */}\r\n            <div className=\"grid grid-cols-1 md:grid-cols-4 gap-4\">\r\n                <div className=\"card bg-base-100 shadow-sm border border-base-200\">\r\n                <div className=\"card-body p-4\">\r\n                    <p className=\"text-sm font-medium text-base-content/70\">CA Total TTC</p>\r\n                    <h3 className=\"text-2xl font-bold text-emerald-600\">{formatCurrency(Math.round(totaux.ca_ttc))} F</h3>\r\n                </div>\r\n                </div>\r\n                <div className=\"card bg-base-100 shadow-sm border border-base-200\">\r\n                <div className=\"card-body p-4\">\r\n                    <p className=\"text-sm font-medium text-base-content/70\">Co├╗t d'Achat (Vendu)</p>\r\n                    <h3 className=\"text-2xl font-bold text-blue-600\">{formatCurrency(Math.round(totaux.cout_achat))} F</h3>\r\n                </div>\r\n                </div>\r\n                <div className=\"card bg-base-100 shadow-sm border border-base-200\">\r\n                <div className=\"card-body p-4\">\r\n                    <p className=\"text-sm font-medium text-base-content/70\">Marge Brute</p>\r\n                    <h3 className=\"text-2xl font-bold text-amber-600\">{formatCurrency(Math.round(totaux.marge_brute))} F</h3>\r\n                    <p className=\"text-xs text-base-content/60\">\r\n                    {totaux.ca_ttc > 0 ? ((totaux.marge_brute / totaux.ca_ttc) * 100).toFixed(1) : 0}% du CA\r\n                    </p>\r\n                </div>\r\n                </div>\r\n                <div className=\"card bg-base-100 shadow-sm border border-base-200\">\r\n                <div className=\"card-body p-4\">\r\n                    <p className=\"text-sm font-medium text-base-content/70\">Unit├®s Vendues</p>\r\n                    <h3 className=\"text-2xl font-bold text-purple-600\">{totaux.quantite_vendue}</h3>\r\n                </div>\r\n                </div>\r\n            </div>\r\n\r\n            {/* Graphique */}\r\n            <div className=\"card bg-base-100 shadow-sm border border-base-200\">\r\n                <div className=\"card-body p-4\">\r\n                <h2 className=\"card-title text-lg font-bold mb-4\">R├®partition du CA par Fournisseur</h2>\r\n                <div className=\"h-80\">\r\n                    <ResponsiveContainer width=\"100%\" height=\"100%\">\r\n                    <BarChart data={stats} margin={{ top: 20, right: 30, left: 20, bottom: 5 }}>\r\n                        <CartesianGrid strokeDasharray=\"3 3\" />\r\n                        <XAxis dataKey=\"nom\" />\r\n                        <YAxis />\r\n                        <Tooltip formatter={(value) => `${formatCurrency(Number(value))} F`} />\r\n                        <Legend />\r\n                        <Bar dataKey=\"ca_ttc\" name=\"Chiffre d'Affaires\" fill=\"#10b981\" />\r\n                        <Bar dataKey=\"marge_brute\" name=\"Marge Brute\" fill=\"#f59e0b\" />\r\n                    </BarChart>\r\n                    </ResponsiveContainer>\r\n                </div>\r\n                </div>\r\n            </div>\r\n\r\n            {/* Tableau d├®taill├® */}\r\n            <div className=\"card bg-base-100 shadow-sm border border-base-200\">\r\n                <div className=\"card-body p-0\">\r\n                <div className=\"overflow-x-auto\">\r\n                    <table className=\"table table-zebra w-full\">\r\n                    <thead>\r\n                        <tr className=\"bg-base-200\">\r\n                        <th>Fournisseur</th>\r\n                        <th className=\"text-right\">Qt├® Vendue</th>\r\n                        <th className=\"text-right\">Co├╗t Achat</th>\r\n                        <th className=\"text-right\">CA TTC</th>\r\n                        <th className=\"text-right\">Marge Brute</th>\r\n                        <th className=\"text-right\">% Marge</th>\r\n                        </tr>\r\n                    </thead>\r\n                    <tbody>\r\n                        {stats.length === 0 ? (\r\n                        <tr>\r\n                            <td colSpan={6} className=\"text-center py-8 text-base-content/50\">\r\n                            Aucune donn├®e pour la p├®riode s├®lectionn├®e\r\n                            </td>\r\n                        </tr>\r\n                        ) : (\r\n                        stats.map((stat) => (\r\n                            <tr key={stat.id}>\r\n                            <td className=\"font-medium\">{stat.nom}</td>\r\n                            <td className=\"text-right\">{stat.quantite_vendue}</td>\r\n                             <td className=\"text-right\">{formatCurrency(Math.round(Number(stat.cout_achat)))} F</td>\r\n                             <td className=\"text-right font-bold\">{formatCurrency(Math.round(Number(stat.ca_ttc)))} F</td>\r\n                             <td className=\"text-right text-success\">{formatCurrency(Math.round(Number(stat.marge_brute)))} F</td>\r\n                            <td className=\"text-right text-sm\">\r\n                                {Number(stat.ca_ttc) > 0 \r\n                                ? ((Number(stat.marge_brute) / Number(stat.ca_ttc)) * 100).toFixed(1) \r\n                                : 0}%\r\n                            </td>\r\n                            </tr>\r\n                        ))\r\n                        )}\r\n                    </tbody>\r\n                    </table>\r\n                </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n      )}\r\n\r\n      {/* TAB 2: PERFORMANCE (Scoring) */}\r\n      {activeTab === 'performance' && (\r\n        <div className=\"space-y-6 animate-fade-in\">\r\n             <div className=\"alert alert-warning shadow-sm\">\r\n                <svg xmlns=\"http://www.w3.org/2000/svg\" className=\"stroke-current shrink-0 h-6 w-6\" fill=\"none\" viewBox=\"0 0 24 24\"><path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth=\"2\" d=\"M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z\" /></svg>\r\n                <div>\r\n                <h3 className=\"font-bold\">Analyse sur 12 mois glissants</h3>\r\n                <div className=\"text-sm\">Scores calcul├®s sur l'historique des r├®ceptions.</div>\r\n                </div>\r\n            </div>\r\n            \r\n            {loadingAnalysis ? (\r\n                 <div className=\"h-64 flex items-center justify-center\">\r\n                    <span className=\"loading loading-spinner loading-lg\"></span>\r\n                 </div>\r\n            ) : (\r\n                <div className=\"grid grid-cols-1 gap-4\">\r\n                     {supplierAnalysis?.map((item) => (\r\n                         <div key={item.id} className=\"card bg-base-100 shadow-sm border border-base-200\">\r\n                             <div className=\"card-body p-4\">\r\n                                 <div className=\"flex justify-between items-start\">\r\n                                     <div>\r\n                                         <h3 className=\"text-xl font-bold\">{item.nom}</h3>\r\n                                         <div className=\"badge badge-lg mt-2 badge-outline\">Score: {item.score_global}/100</div>\r\n                                     </div>\r\n                                     <div className={`radial-progress font-bold text-lg ${\r\n                                        item.score_global >= 80 ? 'text-success' : \r\n                                        item.score_global >= 50 ? 'text-warning' : 'text-error'\r\n                                    }`} style={{ \"--value\": item.score_global, \"--size\": \"4rem\" } as any}>\r\n                                        {item.score_global}\r\n                                    </div>\r\n                                 </div>\r\n                                 \r\n                                 <div className=\"divider my-1\"></div>\r\n\r\n                                 <div className=\"grid grid-cols-3 gap-4 text-center\">\r\n                                     <div>\r\n                                         <div className=\"text-xs uppercase font-bold text-base-content/50\">Volume (30%)</div>\r\n                                          <div className=\"font-bold text-lg\">{formatCurrency(Math.round(item.details.volume.valeur ?? 0))} F</div>\r\n                                         <progress className=\"progress progress-primary w-full\" value={item.details.volume.score} max=\"100\"></progress>\r\n                                     </div>\r\n                                     <div>\r\n                                         <div className=\"text-xs uppercase font-bold text-base-content/50\">Qualit├® (30%)</div>\r\n                                         <div className=\"font-bold text-lg\">{item.details.qualite.incidents} Incidents</div>\r\n                                         <progress className={`progress w-full ${item.details.qualite.score > 80 ? 'progress-success' : 'progress-error'}`} value={item.details.qualite.score} max=\"100\"></progress>\r\n                                     </div>\r\n                                     <div>\r\n                                         <div className=\"text-xs uppercase font-bold text-base-content/50\">R├®gularit├® (40%)</div>\r\n                                         <div className=\"font-bold text-lg\">{item.details.regularite.nb_livraisons} Livraisons</div>\r\n                                         <progress className=\"progress progress-info w-full\" value={item.details.regularite.score} max=\"100\"></progress>\r\n                                     </div>\r\n                                 </div>\r\n                             </div>\r\n                         </div>\r\n                     ))}\r\n                </div>\r\n            )}\r\n        </div>\r\n      )}\r\n\r\n      {/* TAB 3: COMPARATEUR PRIX */}\r\n      {activeTab === 'prix' && (\r\n        <div className=\"space-y-6 animate-fade-in\">\r\n             <div className=\"alert alert-success shadow-sm\">\r\n                <svg xmlns=\"http://www.w3.org/2000/svg\" className=\"stroke-current shrink-0 h-6 w-6\" fill=\"none\" viewBox=\"0 0 24 24\"><path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth=\"2\" d=\"M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z\" /></svg>\r\n                <div>\r\n                <h3 className=\"font-bold\">Opportunit├®s d'├®conomie</h3>\r\n                <div className=\"text-sm\">Produits achet├®s chez plusieurs fournisseurs avec ├®carts de prix significatifs.</div>\r\n                </div>\r\n            </div>\r\n\r\n            {loadingPrix ? (\r\n                <div className=\"h-64 flex items-center justify-center\">\r\n                    <span className=\"loading loading-spinner loading-lg\"></span>\r\n                 </div>\r\n            ) : (\r\n                <div className=\"overflow-x-auto card bg-base-100 shadow-sm border border-base-200\">\r\n                    <table className=\"table table-zebra w-full\">\r\n                        <thead>\r\n                            <tr>\r\n                                <th>Produit</th>\r\n                                <th>├ëcart Max</th>\r\n                                <th>Offres (Prix Moyen)</th>\r\n                                <th>Meilleur Prix</th>\r\n                            </tr>\r\n                        </thead>\r\n                        <tbody>\r\n                            {prixComparaison?.map((prod) => (\r\n                                <tr key={prod.id}>\r\n                                    <td className=\"font-bold max-w-xs truncate\" title={prod.produit}>{prod.produit}</td>\r\n                                    <td>\r\n                                        <span className={`badge ${\r\n                                            prod.ecart_pourcentage > 20 ? 'badge-error text-white' : \r\n                                            prod.ecart_pourcentage > 5 ? 'badge-warning' : 'badge-ghost'\r\n                                        }`}>\r\n                                            {prod.ecart_pourcentage}%\r\n            