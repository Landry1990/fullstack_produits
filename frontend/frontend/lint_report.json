                           );\r\n                        }\r\n                        return (\r\n                            <div key={key} className=\"bg-base-100 rounded-2xl p-6 border border-base-300 shadow-sm flex flex-col justify-center\">\r\n                                <div className=\"text-[10px] font-bold uppercase text-base-content/40 tracking-widest mb-1\">{key.replace(/_/g, ' ')}</div>\r\n                                <div className=\"text-2xl font-black text-base-content\">{formatValue(key, value)}</div>\r\n                            </div>\r\n                        );\r\n                    })}\r\n                </div>\r\n            );\r\n        }\r\n\r\n        // Table Display\r\n        if (Array.isArray(results)) {\r\n            if (results.length === 0) {\r\n                return (\r\n                    <div className=\"flex flex-col items-center justify-center py-20 text-base-content/30 italic\">\r\n                        <Inbox className=\"w-12 h-12 mb-2 opacity-20\" />\r\n                        <p>{t('reports.results.no_result', 'Aucun r├®sultat trouv├® pour cette p├®riode.')}</p>\r\n                    </div>\r\n                );\r\n            }\r\n\r\n            const columns = Object.keys(results[0]).filter(k => !k.startsWith('_') && k !== 'id');\r\n\r\n            return (\r\n                <div className=\"bg-base-100 rounded-2xl border border-base-300 shadow-sm overflow-hidden animate-in fade-in duration-500\">\r\n                    <div className=\"overflow-x-auto\">\r\n                        <table className=\"table table-zebra w-full\">\r\n                            <thead>\r\n                                <tr className=\"bg-base-200/50\">\r\n                                    {columns.slice(0, 8).map(col => (\r\n                                        <th key={col} className=\"text-[10px] font-black uppercase tracking-widest text-base-content/60 py-4\">\r\n                                            {formatColumnHeader(col)}\r\n                                        </th>\r\n                                    ))}\r\n                                    <th className=\"w-10\"></th>\r\n                                </tr>\r\n                            </thead>\r\n                            <tbody>\r\n                                {results.slice(0, 100).map((row, idx) => (\r\n                                    <tr key={idx} className=\"hover:bg-primary/5 transition-colors group\">\r\n                                        {columns.slice(0, 8).map(col => (\r\n                                            <td key={col} className=\"text-sm font-bold text-base-content/80\">\r\n                                                {formatValue(col, row[col])}\r\n                                            </td>\r\n                                        ))}\r\n                                        <td>\r\n                                            <button className=\"btn btn-ghost btn-xs opacity-0 group-hover:opacity-100 transition-opacity\">\r\n                                                <Eye className=\"w-4 h-4\" />\r\n                                            </button>\r\n                                        </td>\r\n                                    </tr>\r\n                                ))}\r\n                            </tbody>\r\n                        </table>\r\n                    </div>\r\n                    {results.length > 100 && !pagination && (\r\n                        <div className=\"p-4 bg-base-50 text-center text-[10px] font-black uppercase text-base-content/30 tracking-[0.2em] border-t border-base-200\">\r\n                            {t('reports.results.limited_display', 'Affichage limit├® aux 100 premiers r├®sultats sur {{total}}', { total: results.length })}\r\n                        </div>\r\n                    )}\r\n                </div>\r\n            );\r\n        }\r\n\r\n        return (\r\n            <div className=\"bg-ba