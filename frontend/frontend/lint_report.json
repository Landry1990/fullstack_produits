v>\r\n            )}\r\n\r\n            <div className=\"flex flex-col gap-3\">\r\n                <button \r\n                  className=\"btn btn-primary btn-lg rounded-xl font-black shadow-lg shadow-primary/20\" \r\n                  onClick={handleCloseCaisse}\r\n                  disabled={loading || !actualAmount}\r\n                >\r\n                    {loading ? <span className=\"loading loading-spinner\"></span> : 'CONFIRMER LA CL├öTURE'}\r\n                </button>\r\n                <div className=\"grid grid-cols-2 gap-3\">\r\n                    <button className=\"btn btn-outline border-base-300 font-bold flex items-center justify-center gap-2\" onClick={handleImprimerCloture}>\r\n                        <Printer className=\"w-5 h-5\" /> TICKET\r\n                    </button>\r\n                    <button className=\"btn btn-ghost font-bold opacity-50\" onClick={() => setIsClosingModalOpen(false)}>\r\n                        ANNULER\r\n                    </button>\r\n                </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </dialog>\r\n      \r\n      <CashMovementModal \r\n        isOpen={isMovementModalOpen}\r\n        onClose={() => setIsMovementModalOpen(false)}\r\n        onSuccess={fetchData}\r\n      />\r\n    </div>\r\n  )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Projet Fullstack\\fullstack_produits\\frontend\\frontend\\src\\components\\Layout.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Projet Fullstack\\fullstack_produits\\frontend\\frontend\\src\\components\\Login.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Projet Fullstack\\fullstack_produits\\frontend\\frontend\\src\\components\\LotSelectionModal.tsx","messages