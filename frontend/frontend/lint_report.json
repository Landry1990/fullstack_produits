);\r\n        doc.text(t('stock.inventaire.pdf.total_global', {\r\n            sign: totalGlobal > 0 ? '+' : '',\r\n            amount: totalGlobal.toFixed(0)\r\n        }), 14, currentY);\r\n\r\n        doc.save(`inventaire_${activeInventaire.id} _ecarts.pdf`);\r\n    };\r\n\r\n    return {\r\n        generateEtatPDF,\r\n        generateEcartsPDF\r\n    };\r\n};\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Projet Fullstack\\fullstack_produits\\frontend\\frontend\\src\\hooks\\inventaire\\useProductSearch.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Projet Fullstack\\fullstack_produits\\frontend\\frontend\\src\\hooks\\useAjustementsData.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Projet Fullstack\\fullstack_produits\\frontend\\frontend\\src\\hooks\\useAudit.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Projet Fullstack\\fullstack_produits\\frontend\\frontend\\src\\hooks\\useAutoLogout.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Projet Fullstack\\fullstack_produits\\frontend\\frontend\\src\\hooks\\useAvoirsData.ts","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'fournisseurSearch'. Either include it or remove the dependency array.","line":163,"column":8,"nodeType":"ArrayExpression","endLine":163,"endColumn":46,"suggestions":[{"desc":"Update the dependencies array to be: [debouncedFournisseurSearch, fournisseurSearch, viewMode]","fix":{"range":[6893