hing settings...\")\n        setLoading(true)\n        try {\n            const url = `${apiBaseUrl}/api/loyalty-settings/`\n            console.log(\"LoyaltyConfigModal: GET\", url)\n            let res = await axios.get(url)\n            console.log(\"LoyaltyConfigModal: Response\", res.data)\n            \n            // Handle paginated, array, or single object response\n            let data = res.data\n            if (data && typeof data === 'object' && 'results' in data && Array.isArray(data.results)) {\n                data = data.results[0]\n            } else if (Array.isArray(data)) {\n                data = data[0]\n            }\n            \n            if (data && typeof data === 'object' && 'amount_per_point' in data) {\n                console.log(\"LoyaltyConfigModal: Setting data\", data)\n                setSettings(data)\n            } else {\n                console.warn(\"LoyaltyConfigModal: No data found, using defaults\")\n                // Fallback default values if backend returns empty\n                setSettings({\n                    id: 0,\n                    amount_per_point: \"1000\",\n                    point_value: \"10\",\n                    auto_reward_threshold: 0,\n                    auto_reward_percent: \"0\"\n                } as LoyaltySetting)\n            }\n        } catch (err) {\n            console.error(\"LoyaltyConfigModal: Fetch error\", err)\n            // Even on error, set default settings so the modal isn't empty\n            setSettings({\n                id: 0,\n                amount_per_point: \"1000\",\n                point_value: \"10\",\n                auto_reward_threshold: 0,\n                auto_reward_percent: \"0\"\n            } as LoyaltySetting)\n            toast.error('Erreur lors du chargement des param├¿tres')\n        } finally {\n            setLoading(false)\n        }\n    }\n\n    const handleSave = async (e: React.FormEvent) => {\n        e.preventDefault()\n        if (!settings) return\n        setSaving(true)\n        try {\n            // For singleton, use PUT to update existing or POST will handle it\n            // Check if settings has an id\n            if (settings.id) {\n                await axios.put(`${apiBaseUrl}/api/loyalty-settings/${settings.id}/`, settings)\n            } else {\n                // POST will use update_or_create in backend\n                await axios.post(`${apiBaseUrl}/api/loyalty-settings/`, settings)\n            }\n            onClose()\n            toast.success('Configuration enregistr├®e !')\n        } catch (err) {\n            toast.error('Erreur enregistrement')\n            console.error(err)\n        } finally {\n            setSaving(false)\n        }\n    }\n\n    return (\n        <PremiumModal\n            isOpen={isOpen}\n            onClose={onClose}\n            title=\"­ƒÆÄ Configuration Fid├®lit├®\"\n            subtitle=\"Param├®trer le programme de fid├®lit├®\"\n            icon={\n                <svg xmlns=\"http://www.w3.org/2000/svg\" className=\"h-5 w-5 text-purple-600\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                    <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth=\"2\" d=\"M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z\" />\n                </svg>\n            }\n            gradientFrom=\"purple-500/10\"\n            gradientVia=\"primary/5\"\n            gradientTo=\"purple-500/10\"\n            disableClose={saving}\n        >\n            <div className=\"p-6\">\n                {loading ? (\n                    <div className=\"flex justify-center py-8\"><span className=\"loading loading-spinner text-primary\"></span></div>\n                ) : settings ? (\n                    <form onSubmit={handleSave} className=\"space-y-5\">\n                        <div>\n                            <label className=\"block text-xs font-bold uppercase tracking-wider text-gray-400 mb-2\">Montant d'achat pour 1 point (FCFA)</label>\n                            <input \n                                type=\"number\" \n                                className=\"input input-bordered w-full h-12 rounded-xl\"\n                                value={settings.amount_per_point}\n                                onChange={e => setSettings({...settings, amount_per_point: e.target.value})}\n                            />\n                            <p className=\"text-xs text-gray-400 mt-1\">Ex: 1000 = 1 point par tranche de 1000 F</p>\n                        </div>\n\n                        <div className=\"divider text-xs uppercase tracking-wider\">Usage Manuel</div>\n\n                        <div>\n                            <label className=\"block text-xs font-bold uppercase tracking-wider text-gray-400 mb-2\">Valeur d'un point (FCFA)</label>\n                            <input \n                                type=\"number\" \n                                className=\"input input-bordered w-full h-12 rounded-xl\"\n                                value={settings.point_value}\n                                onChange={e => setSettings({...settings, point_value: e.target.value})}\n                            />\n                            <p className=\"text-xs text-gray-400 mt-1\">Si utilis├® comme monnaie. Ex: 10 F</p>\n                        </div>\n\n                        <div className=\"divider text-xs uppercase tracking-wider\">R├®compense Automatique</div>\n\n                        <div className=\"grid grid-cols-2 gap-4\">\n                            <div>\n                                <label className=\"block text-xs font-bold uppercase tracking-wider text-gray-400 mb-2\">Seuil (Points)</label>\n                                <input \n                                    type=\"number\" \n                                    className=\"input input-bordered w-full h-12 rounded-xl\"\n                                    value={settings.auto_reward_threshold}\n                                    onChange={e => setSettings({...settings, auto_reward_threshold: parseInt(e.target.value) || 0})}\n                                />\n                                <p className=\"text-xs text-gray-400 mt-1\">0 = D├®sactiv├®</p>\n                            </div>\n                            <div>\n                                <label className=\"block text-xs font-bold uppercase tracking-wider text-gray-400 mb-2\">Remise (%)</label>\n                                <input \n                                    type=\"number\" \n                                    className=\"input input-bordered w-full h-12 rounded-xl\"\n                                    step=\"0.01\"\n                                    value={settings.auto_reward_percent}\n                                    onChange={e => setSettings({...settings, auto_reward_percent: e.target.value})}\n                                />\n                                <p className=\"text-xs text-gray-400 mt-1\">Ex: 5.00 pour 5%</p>\n                            </div>\n                        </div>\n\n                        <div className=\"flex justify-end gap-3 pt-2\">\n                             <button type=\"button\" className=\"btn btn-ghost px-6 rounded-xl\" onClick={onClose} disabled={saving}>Annuler</button>\n                             <button type=\"submit\" className=\"btn btn-primary px-8 rounded-xl shadow-lg shadow-primary/20\" disabled={saving}>\n                                {saving && <span className=\"loading loading-spinner\"></span>}\n                                Enregistrer\n                             </button>\n                        </div>\n                    </form>\n                ) : (\n                    <div className=\"text-error text-center py-8\">Erreur de chargement</div>\n                )}\n            </div>\n        </PremiumModal>\n    )\n}\n\n","usedDeprecatedRules":[]},{"filePath":"C:\\Projet Fullstack\\fullstack_produits\\frontend\\frontend\\src\\components\\Maintenance.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":78,"column":60,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":78,"endColumn":63,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[2474,2477],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[2474,2477],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":206,"column":19,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":206,"endColumn":22,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[6203,6206],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[6203,6206],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":219,"column":19,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":219,"endColumn":22,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[6604,6607],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[6604,6607],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":3,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useEffect } from 'react';\r\nimport axios from 'axios';\r\nimport {\r\n  Trash2, Download, Eye, ShieldAlert, AlertTriangle,\r\n  CheckSquare, Square, Calendar, Loader2,\r\n  Wrench, ChevronDown, ChevronUp, Database, Clock, Save\r\n} from 'lucide-react';\r\nimport toast from 'react-hot-toast';\r\nimport { formatNumber } from '../utils/formatters';\r\n\r\ninterface PurgeTable {\r\n  key: string;\r\n  label: string;\r\n  children: string[];\r\n}\r\n\r\ninterface PreviewResult {\r\n  key: string;\r\n  label: string;\r\n  count: number;\r\n  children: { label: string; count: number }[];\r\n}\r\n\r\ninterface PurgeResult {\r\n  key: string;\r\n  label: string;\r\n  deleted: number;\r\n}\r\n\r\n// Group tables by category for display\r\nconst TABLE_CATEGORIES: Record<string, { label: string; icon: string; keys: string[] }> = {\r\n  ventes: {\r\n    label: '­ƒÆ░ Ventes & Facturation',\r\n    icon: '­ƒÆ░',\r\n    keys: ['factures', 'caisse', 'releves', 'coupons', 'promis'],\r\n  },\r\n  achats: {\r\n    label: '­ƒôª Achats & Fournisseurs',\r\n    icon: '­ƒôª',\r\n    keys: ['commandes', 'avoirs', 'paiements_fournisseur'],\r\n  },\r\n  stock: {\r\n    label: '­ƒôè Stock',\r\n    icon: '­ƒôè',\r\n    keys: ['mouvements_stock', 'ajustements_stock'],\r\n  },\r\n  caisse: {\r\n    label: '­ƒÅª Caisse',\r\n    icon: '­ƒÅª',\r\n    keys: ['clotures_caisse', 'mouvements_caisse'],\r\n  },\r\n  audit: {\r\n    label: '­ƒôï Audit & Logs',\r\n    icon: '­ƒôï',\r\n    keys: ['ordonnancier', 'audit_logs', 'activity_logs', 'sms_logs'],\r\n  },\r\n  objectifs: {\r\n    label: '­ƒÄ» Objectifs',\r\n    icon: '­ƒÄ»',\r\n    keys: ['objectifs'],\r\n  },\r\n};\r\n\r\nexport default function Maintenance() {\r\n  const [tables, setTables] = useState<PurgeTable[]>([]);\r\n  const [selectedTables, setSelectedTables] = useState<Set<string>>(new Set());\r\n  const [dateFrom, setDateFrom] = useState('');\r\n  const [dateTo, setDateTo] = useState('');\r\n  const [preview, setPreview] = useState<PreviewResult[] | null>(null);\r\n  const [purgeResults, setPurgeResults] = useState<PurgeResult[] | null>(null);\r\n  const [loading, setLoading] = useState(false);\r\n  const [exporting, setExporting] = useState(false);\r\n  const [showConfirmModal, setShowConfirmModal] = useState(false);\r\n  const [password, setPassword] = useState('');\r\n  const [purging, setPurging] = useState(false);\r\n  const [expandedCategories, setExpandedCategories] = useState<Set<string>>(new Set(Object.keys(TABLE_CATEGORIES)));\r\n  const [backupLoading, setBackupLoading] = useState(false);\r\n  const [pharmacySettings, setPharmacySettings] = useState<any>(null);\r\n  const [savingSettings, setSavingSettings] = useState(false);\r\n\r\n  // Fetch available tables and pharmacy settings\r\n  useEffect(() => {\r\n    axios.get('/api/maintenance/tables/')\r\n      .then(res => setTables(res.data))\r\n      .catch(() => toast.error('Erreur chargement des tables'));\r\n\r\n    axios.get('/api/pharmacy-settings/')\r\n      .then(res => setPharmacySettings(res.data))\r\n      .catch(() => console.error('Erreur chargement param├¿tres pharmacie'));\r\n  }, []);\r\n\r\n  const toggleTable = (key: string) => {\r\n    setSelectedTables(prev => {\r\n      const next = new Set(prev);\r\n      if (next.has(key)) next.delete(key);\r\n      else next.add(key);\r\n      return next;\r\n    });\r\n    setPreview(null);\r\n    setPurgeResults(null);\r\n  };\r\n\r\n  const toggleCategory = (catKeys: string[]) => {\r\n    const allSelected = catKeys.every(k => selectedTables.has(k));\r\n    setSelectedTables(prev => {\r\n      const next = new Set(prev);\r\n      catKeys.forEach(k => {\r\n        if (allSelected) next.delete(k);\r\n        else next.add(k);\r\n      });\r\n      return next;\r\n    });\r\n    setPreview(null);\r\n    setPurgeResults(null);\r\n  };\r\n\r\n  const toggleExpandCategory = (cat: string) => {\r\n    setExpandedCategories(prev => {\r\n      const next = new Set(prev);\r\n      if (next.has(cat)) next.delete(cat);\r\n      else next.add(cat);\r\n      return next;\r\n    });\r\n  };\r\n\r\n  const selectAll = () => {\r\n    setSelectedTables(new Set(tables.map(t => t.key)));\r\n    setPreview(null);\r\n    setPurgeResults(null);\r\n  };\r\n\r\n  const deselectAll = () => {\r\n    setSelectedTables(new Set());\r\n    setPreview(null);\r\n    setPurgeResults(null);\r\n  };\r\n\r\n  const handlePreview = async () => {\r\n    if (selectedTables.size === 0) {\r\n      toast.error('S├®lectionnez au moins une table');\r\n      return;\r\n    }\r\n    setLoading(true);\r\n    setPurgeResults(null);\r\n    try {\r\n      const res = await axios.post('/api/maintenance/preview/', {\r\n        tables: Array.from(selectedTables),\r\n        date_from: dateFrom || null,\r\n        date_to: dateTo || null,\r\n      });\r\n      setPreview(res.data);\r\n    } catch {\r\n      toast.error('Erreur lors de la pr├®visualisation');\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  };\r\n\r\n  const handleExport = async () => {\r\n    if (selectedTables.size === 0) {\r\n      toast.error('S├®lectionnez au moins une table');\r\n      return;\r\n    }\r\n    setExporting(true);\r\n    try {\r\n      const res = await axios.post('/api/maintenance/export/', {\r\n        tables: Array.from(selectedTables),\r\n        date_from: dateFrom || null,\r\n        date_to: dateTo || null,\r\n      }, { responseType: 'blob' });\r\n\r\n      const url = window.URL.createObjectURL(new Blob([res.data]));\r\n      const link = document.createElement('a');\r\n      link.href = url;\r\n      link.setAttribute('download', `purge_backup_${new Date().toISOString().slice(0, 10)}.zip`);\r\n      document.body.appendChild(link);\r\n      link.click();\r\n      link.remove();\r\n      window.URL.revokeObjectURL(url);\r\n      toast.success('Export CSV t├®l├®charg├® !');\r\n    } catch {\r\n      toast.error('Erreur lors de l\\'export');\r\n    } finally {\r\n      setExporting(false);\r\n    }\r\n  };\r\n\r\n  const handlePurge = async () => {\r\n    if (!password) {\r\n      toast.error('Mot de passe requis');\r\n      return;\r\n    }\r\n    setPurging(true);\r\n    try {\r\n      const res = await axios.post('/api/maintenance/purge/', {\r\n        tables: Array.from(selectedTables),\r\n        date_from: dateFrom || null,\r\n        date_to: dateTo || null,\r\n        password,\r\n      });\r\n      setPurgeResults(res.data.results);\r\n      setPreview(null);\r\n      setShowConfirmModal(false);\r\n      setPassword('');\r\n      toast.success('Purge effectu├®e avec succ├¿s !');\r\n    } catch (err: any) {\r\n      const msg = err.response?.data?.detail || 'Erreur lors de la purge';\r\n      toast.error(msg);\r\n    } finally {\r\n      setPurging(false);\r\n    }\r\n  };\r\n\r\n  const handleManualBackup = async () => {\r\n    setBackupLoading(true);\r\n    try {\r\n      const res = await axios.post('/api/maintenance/backup/');\r\n      toast.success(res.data.message || 'Sauvegarde termin├®e !');\r\n    } catch (err: any) {\r\n      toast.error(err.response?.data?.detail || 'Erreur lors de la sauvegarde');\r\n    } finally {\r\n      setBackupLoading(false);\r\n    }\r\n  };\r\n\r\n  const saveBackupSettings = async () => {\r\n    if (!pharmacySettings) return;\r\n    setSavingSettings(true);\r\n    try {\r\n      await axios.put('/api/pharmacy-settings/', {\r\n        backup_enabled: pharmacySettings.backup_enabled,\r\n        backup_time: pharmacySettings.backup_time,\r\n        secondary_backup_path: pharmacySettings.secondary_backup_path,\r\n      });\r\n      toast.success('Param├¿tres de sauvegarde enregistr├®s !');\r\n    } catch {\r\n      toast.error('Erreur lors de l\\'enregistrement');\r\n    } finally {\r\n      setSavingSettings(false);\r\n    }\r\n  };\r\n\r\n  const totalPreviewCount = preview?.reduce((sum, p) => {\r\n    const childTotal = p.children.reduce((cs, c) => cs + c.count, 0);\r\n    return sum + p.count + childTotal;\r\n  }, 0) ?? 0;\r\n\r\n  const tableMap = new Map(tables.map(t => [t.key, t]));\r\n\r\n  return (\r\n    <div className=\"p-4 md:p-6 max-w-5xl mx-auto\">\r\n      {/* Header */}\r\n      <div className=\"flex items-center gap-3 mb-6\">\r\n        <div className=\"p-3 rounded-xl bg-gradient-to-br from-red-500/20 to-orange-500/20\">\r\n          <Wrench className=\"w-7 h-7 text-red-400\" />\r\n        </div>\r\n        <div>\r\n          <h1 className=\"text-2xl font-bold\">Maintenance &amp; Purge</h1>\r\n          <p className=\"text-sm text-base-content/60\">Nettoyage s├®curis├® des donn├®es transactionnelles</p>\r\n        </div>\r\n      </div>\r\n\r\n      {/* Warning Banner */}\r\n      <div className=\"alert alert-warning mb-6 shadow-lg\">\r\n        <AlertTriangle className=\"w-5 h-5\" />\r\n        <div>\r\n          <h3 className=\"font-bold\">Op├®ration irr├®versible</h3>\r\n          <p className=\"text-sm\">Les donn├®es supprim├®es ne pourront pas ├¬tre r├®cup├®r├®es. Exportez toujours une sauvegarde CSV avant de purger.</p>\r\n        </div>\r\n      </div>\r\n\r\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\r\n        {/* Left Column: Table Selection */}\r\n        <div className=\"lg:col-span-2\">\r\n          <div className=\"card bg-base-100 shadow-xl\">\r\n            <div className=\"card-body\">\r\n              <div className=\"flex items-center justify-between mb-4\">\r\n                <h2 className=\"card-title text-lg\">\r\n                  <CheckSquare className=\"w-5 h-5 text-primary\" />\r\n                  Tables ├á purger\r\n                </h2>\r\n                <div className=\"flex gap-2\">\r\n                  <button className=\"btn btn-xs btn-ghost\" onClick={selectAll}>Tout s├®lectionner</button>\r\n                  <button className=\"btn btn-xs btn-ghost\" onClick={deselectAll}>Tout d├®s├®lectionner</button>\r\n                </div>\r\n              </div>\r\n\r\n              <div className=\"space-y-2\">\r\n                {Object.entries(TABLE_CATEGORIES).map(([catKey, cat]) => {\r\n                  const availableKeys = cat.keys.filter(k => tableMap.has(k));\r\n                  if (availableKeys.length === 0) return null;\r\n                  const allCatSelected = availableKeys.every(k => selectedTables.has(k));\r\n                  const someCatSelected = availableKeys.some(k => selectedTables.has(k));\r\n                  const isExpanded = expandedCategories.has(catKey);\r\n\r\n                  return (\r\n                    <div key={catKey} className=\"border border-base-300 rounded-lg overflow-hidden\">\r\n                      {/* Category header */}\r\n                      <div\r\n                        className={`flex items-center justify-between px-4 py-3 cursor-pointer transition-colors ${someCatSelected ? 'bg-primary/10' : 'bg-base-200/50 hover:bg-base-200'}`}\r\n                        onClick={() => toggleExpandCategory(catKey)}\r\n                      >\r\n                        <div className=\"flex items-center gap-3\">\r\n                          <button\r\n                            className=\"btn btn-xs btn-ghost p-0\"\r\n                            onClick={(e) => { e.stopPropagation(); toggleCategory(availableKeys); }}\r\n                          >\r\n                            {allCatSelected ? (\r\n                              <CheckSquare className=\"w-4 h-4 text-primary\" />\r\n                            ) : someCatSelected ? (\r\n                              <CheckSquare className=\"w-4 h-4 text-primary/50\" />\r\n                            ) : (\r\n                              <Square className=\"w-4 h-4 text-base-content/40\" />\r\n                            )}\r\n                          </button>\r\n                          <span className=\"font-semibold text-sm\">{cat.label}</span>\r\n                          <span className=\"badge badge-sm badge-ghost\">{availableKeys.length}</span>\r\n                        </div>\r\n                        {isExpanded ? <ChevronUp className=\"w-4 h-4\" /> : <ChevronDown className=\"w-4 h-4\" />}\r\n                      </div>\r\n\r\n                      {/* Category items */}\r\n                      {isExpanded && (\r\n                        <div className=\"divide-y divide-base-200\">\r\n                          {availableKeys.map(key => {\r\n                            const table = tableMap.get(key)!;\r\n                            const isSelected = selectedTables.has(key);\r\n                            return (\r\n                              <label\r\n                                key={key}\r\n                                className={`flex items-center gap-3 px-6 py-2.5 cursor-pointer transition-colors ${isSelected ? 'bg-primary/5' : 'hover:bg-base-200/30'}`}\r\n                              >\r\n                                <input\r\n                                  type=\"checkbox\"\r\n                                  className=\"checkbox checkbox-sm checkbox-primary\"\r\n                                  checked={isSelected}\r\n                                  onChange={() => toggleTable(key)}\r\n                                />\r\n                                <span className=\"text-sm flex-1\">{table.label}</span>\r\n                                {table.children.length > 0 && (\r\n                                  <span className=\"text-xs text-base-content/50\">\r\n                                    +{table.children.length} sous-table{table.children.length > 1 ? 's' : ''}\r\n                                  </span>\r\n                                )}\r\n                              </label>\r\n                            );\r\n                          })}\r\n                        </div>\r\n                      )}\r\n                    </div>\r\n                  );\r\n                })}\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        {/* Right Column: Controls */}\r\n        <div className=\"space-y-4\">\r\n          {/* Date Range */}\r\n          <div className=\"card bg-base-100 shadow-xl\">\r\n            <div className=\"card-body\">\r\n              <h2 className=\"card-title text-lg mb-2\">\r\n                <Calendar className=\"w-5 h-5 text-secondary\" />\r\n                P├®riode\r\n              </h2>\r\n              <div className=\"form-control mb-2\">\r\n                <label className=\"label\"><span className=\"label-text text-xs\">Date de d├®but</span></label>\r\n                <input\r\n                  type=\"date\"\r\n                  className=\"input input-bordered input-sm\"\r\n                  value={dateFrom}\r\n                  onChange={e => { setDateFrom(e.target.value); setPreview(null); setPurgeResults(null); }}\r\n                />\r\n              </div>\r\n              <div className=\"form-control\">\r\n                <label className=\"label\"><span className=\"label-text text-xs\">Date de fin</span></label>\r\n                <input\r\n                  type=\"date\"\r\n                  className=\"input input-bordered input-sm\"\r\n                  value={dateTo}\r\n                  onChange={e => { setDateTo(e.target.value); setPreview(null); setPurgeResults(null); }}\r\n                />\r\n              </div>\r\n              {!dateFrom && !dateTo && (\r\n                <p className=\"text-xs text-warning mt-2\">ÔÜá´©Å Sans date, TOUTES les donn├®es seront concern├®es</p>\r\n              )}\r\n            </div>\r\n          </div>\r\n\r\n          {/* Action Buttons */}\r\n          <div className=\"card bg-base-100 shadow-xl\">\r\n            <div className=\"card-body gap-3\">\r\n              <h2 className=\"card-title text-lg\">Actions</h2>\r\n\r\n              <button\r\n                className=\"btn btn-primary btn-sm w-full gap-2\"\r\n                onClick={handlePreview}\r\n                disabled={loading || selectedTables.size === 0}\r\n              >\r\n                {loading ? <Loader2 className=\"w-4 h-4 animate-spin\" /> : <Eye className=\"w-4 h-4\" />}\r\n                Pr├®visualiser\r\n              </button>\r\n\r\n              <button\r\n                className=\"btn btn-info btn-sm btn-outline w-full gap-2\"\r\n                onClick={handleExport}\r\n                disabled={exporting || selectedTables.size === 0}\r\n              >\r\n                {exporting ? <Loader2 className=\"w-4 h-4 animate-spin\" /> : <Download className=\"w-4 h-4\" />}\r\n                Exporter CSV (backup)\r\n              </button>\r\n\r\n              <div className=\"divider my-0\"></div>\r\n\r\n              <button\r\n                className=\"btn btn-error btn-sm w-full gap-2\"\r\n                onClick={() => { if (selectedTables.size > 0) setShowConfirmModal(true); else toast.error('S├®lectionnez des tables'); }}\r\n                disabled={selectedTables.size === 0}\r\n              >\r\n                <Trash2 className=\"w-4 h-4\" />\r\n                Purger les donn├®es\r\n              </button>\r\n            </div>\r\n          </div>\r\n\r\n          {/* Backup Section */}\r\n          <div className=\"card bg-base-100 shadow-xl border border-primary/20\">\r\n            <div className=\"card-body gap-4\">\r\n              <h2 className=\"card-title text-lg flex items-center gap-2\">\r\n                <Database className=\"w-5 h-5 text-primary\" />\r\n                Sauvegarde\r\n              </h2>\r\n\r\n              <div className=\"space-y-4\">\r\n                {/* Manual Backup */}\r\n                <div>\r\n                  <p className=\"text-xs text-base-content/60 mb-2\">Lancer une sauvegarde compl├¿te de la base de donn├®es (SQL compress├®).</p>\r\n                  <button\r\n                    className=\"btn btn-primary btn-sm w-full gap-2\"\r\n                    onClick={handleManualBackup}\r\n                    disabled={backupLoading}\r\n                  >\r\n                    {backupLoading ? <Loader2 className=\"w-4 h-4 animate-spin\" /> : <Download className=\"w-4 h-4\" />}\r\n                    Sauvegarder maintenant\r\n                  </button>\r\n                </div>\r\n\r\n                <div className=\"divider my-0\"></div>\r\n\r\n                {/* Scheduled Backup */}\r\n                <div className=\"space-y-3\">\r\n                  <h3 className=\"text-xs font-bold uppercase tracking-wider text-base-content/50 flex items-center gap-2\">\r\n                    <Clock className=\"w-4 h-4\" />\r\n                    Automatique\r\n                  </h3>\r\n                  \r\n                  <div className=\"form-control\">\r\n                    <label className=\"label cursor-pointer justify-start gap-3 p-0\">\r\n                      <input \r\n                        type=\"checkbox\" \r\n                        className=\"toggle toggle-primary toggle-sm\" \r\n                        checked={pharmacySettings?.backup_enabled || false}\r\n                        onChange={e => setPharmacySettings({...pharmacySettings, backup_enabled: e.target.checked})}\r\n                      />\r\n                      <span className=\"label-text\">Activer la sauvegarde auto</span>\r\n                    </label>\r\n                  </div>\r\n\r\n                  <div className=\"form-control\">\r\n                    <label className=\"label p-0 py-1\">\r\n                      <span className=\"label-text text-xs\">Heure programm├®e</span>\r\n                    </label>\r\n                    <input \r\n                      type=\"time\" \r\n                      className=\"input input-bordered input-sm w-full\" \r\n                      value={pharmacySettings?.backup_time?.substring(0, 5) || \"02:00\"}\r\n                      onChange={e => setPharmacySettings({...pharmacySettings, backup_time: e.target.value})}\r\n                    />\r\n                  </div>\r\n\r\n                  <div className=\"form-control\">\r\n                    <label className=\"label p-0 py-1\">\r\n                      <span className=\"label-text text-xs\">Cl├® USB / Chemin externe</span>\r\n                    </label>\r\n                    <input \r\n                      type=\"text\" \r\n                      className=\"input input-bordered input-sm w-full\" \r\n                      placeholder=\"Ex: E:\\Backups_Pharma\"\r\n                      value={pharmacySettings?.secondary_backup_path || \"\"}\r\n                      onChange={e => setPharmacySettings({...pharmacySettings, secondary_backup_path: e.target.value})}\r\n                    />\r\n                  </div>\r\n\r\n                  <button\r\n                    className=\"btn btn-outline btn-primary btn-xs w-full gap-2 mt-2\"\r\n                    onClick={saveBackupSettings}\r\n                    disabled={savingSettings || !pharmacySettings}\r\n                  >\r\n                    {savingSettings ? <Loader2 className=\"w-3 h-3 animate-spin\" /> : <Save className=\"w-3 h-3\" />}\r\n                    Enregistrer les param├¿tres\r\n                  </button>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n\r\n\r\n          {/* Selection Summary */}\r\n          <div className=\"card bg-base-200/50\">\r\n            <div className=\"card-body py-3\">\r\n              <p className=\"text-sm\">\r\n                <span className=\"font-bold text-primary\">{selectedTables.size}</span> table{selectedTables.size !== 1 ? 's' : ''} s├®lectionn├®e{selectedTables.size !== 1 ? 's' : ''}\r\n              </p>\r\n              {dateFrom && <p className=\"text-xs text-base-content/60\">Du: {dateFrom}</p>}\r\n              {dateTo && <p className=\"text-xs text-base-content/60\">Au: {dateTo}</p>}\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      {/* Preview Results */}\r\n      {preview && (\r\n        <div className=\"card bg-base-100 shadow-xl mt-6\">\r\n          <div className=\"card-body\">\r\n            <h2 className=\"card-title text-lg mb-4\">\r\n              <Eye className=\"w-5 h-5 text-info\" />\r\n              Pr├®visualisation ÔÇö <span className=\"text-error\">{formatNumber(totalPreviewCount)}</span> lignes ├á supprimer\r\n            </h2>\r\n            <div className=\"overflow-x-auto\">\r\n              <table className=\"table table-sm table-zebra\">\r\n                <thead>\r\n                  <tr>\r\n                    <th>Table</th>\r\n                    <th className=\"text-right\">Lignes</th>\r\n                    <th>Sous-tables</th>\r\n                  </tr>\r\n                </thead>\r\n                <tbody>\r\n                  {preview.map(p => (\r\n                    <tr key={p.key}>\r\n                      <td className=\"font-medium\">{p.label}</td>\r\n                      <td className=\"text-right\">\r\n                        <span className={`badge ${p.count > 0 ? 'badge-error' : 'badge-ghost'} badge-sm`}>\r\n                          {formatNumber(p.count)}\r\n                        </span>\r\n                      </td>\r\n                      <td>\r\n                        {p.children.length > 0 ? (\r\n                          <div className=\"flex gap-2 flex-wrap\">\r\n                            {p.children.map((c, i) => (\r\n                              <span key={i} className=\"badge badge-sm badge-outline\">\r\n                                {c.label}: {formatNumber(c.count)}\r\n                              </span>\r\n                            ))}\r\n                          </div>\r\n                        ) : (\r\n                          <span className=\"text-base-content/30 text-xs\">ÔÇö</span>\r\n                        )}\r\n                      </td>\r\n                    </tr>\r\n                  ))}\r\n                </tbody>\r\n              </table>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      )}\r\n\r\n      {/* Purge Results */}\r\n      {purgeResults && (\r\n        <div className=\"card bg-success/10 border border-success/30 shadow-xl mt-6\">\r\n          <div className=\"card-body\">\r\n            <h2 className=\"card-title text-lg text-success mb-4\">\r\n              <Trash2 className=\"w-5 h-5\" />\r\n              Purge termin├®e\r\n            </h2>\r\n            <div className=\"overflow-x-auto\">\r\n              <table className=\"table table-sm\">\r\n                <thead>\r\n                  <tr>\r\n                    <th>Table</th>\r\n                    <th className=\"text-right\">Lignes supprim├®es</th>\r\n                  </tr>\r\n                </thead>\r\n                <tbody>\r\n                  {purgeResults.map(r => (\r\n                    <tr key={r.key}>\r\n                      <td>{r.label}</td>\r\n                      <td className=\"text-right font-bold text-success\">{formatNumber(r.deleted)}</td>\r\n                    </tr>\r\n                  ))}\r\n                </tbody>\r\n              </table>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      )}\r\n\r\n      {/* Confirmation Modal */}\r\n      {showConfirmModal && (\r\n        <div className=\"modal modal-open\">\r\n          <div className=\"modal-box max-w-md\">\r\n            <div className=\"flex items-center gap-3 mb-4\">\r\n              <div className=\"p-2 rounded-full bg-error/20\">\r\n                <ShieldAlert className=\"w-6 h-6 text-error\" />\r\n              </div>\r\n              <h3 className=\"font-bold text-lg\">Confirmation de purge</h3>\r\n            </div>\r\n\r\n            <div className=\"alert alert-error mb-4\">\r\n              <AlertTriangle className=\"w-5 h-5\" />\r\n              <span className=\"text-sm\">\r\n                Cette action va <strong>supprimer d├®finitivement</strong> les donn├®es s├®lectionn├®es.\r\n                Pensez ├á exporter une sauvegarde CSV avant de continuer.\r\n              </span>\r\n            </div>\r\n\r\n            <div className=\"bg-base-200 rounded-lg p-3 mb-4 max-h-32 overflow-y-auto\">\r\n              <p className=\"text-xs font-semibold mb-1\">Tables concern├®es :</p>\r\n              <ul className=\"text-xs space-y-0.5\">\r\n                {Array.from(selectedTables).map(key => {\r\n                  const t = tableMap.get(key);\r\n                  return <li key={key}>ÔÇó {t?.label || key}</li>;\r\n                })}\r\n              </ul>\r\n              {(dateFrom || dateTo) && (\r\n                <p className=\"text-xs mt-2 text-base-content/60\">\r\n                  P├®riode : {dateFrom || '...'} ÔåÆ {dateTo || '...'}\r\n                </p>\r\n              )}\r\n            </div>\r\n\r\n            <div className=\"form-control mb-4\">\r\n              <label className=\"label\">\r\n                <span className=\"label-text text-sm font-semibold\">Mot de passe superadmin</span>\r\n              </label>\r\n              <input\r\n                type=\"password\"\r\n                className=\"input input-bordered\"\r\n                placeholder=\"Saisissez votre mot de passe\"\r\n                value={password}\r\n                onChange={e => setPassword(e.target.value)}\r\n                onKeyDown={e => { if (e.key === 'Enter') handlePurge(); }}\r\n                autoFocus\r\n              />\r\n            </div>\r\n\r\n            <div className=\"modal-action\">\r\n              <button className=\"btn btn-ghost\" onClick={() => { setShowConfirmModal(false); setPassword(''); }}>\r\n                Annuler\r\n              </button>\r\n              <button\r\n                className=\"btn btn-error gap-2\"\r\n                onClick={handlePurge}\r\n                disabled={purging || !password}\r\n              >\r\n                {purging ? <Loader2 className=\"w-4 h-4 animate-spin\" /> : <Trash2 className=\"w-4 h-4\" />}\r\n                Confirmer la purge\r\n              </button>\r\n            </div>\r\n          </div>\r\n          <div className=\"modal-backdrop\" onClick={() => { setShowConfirmModal(false); setPassword(''); }}></div>\r\n        </div>\r\n      )}\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Projet Fullstack\\fullstack_produits\\frontend\\frontend\\src\\components\\ModuleFinancier.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":792,"column":92,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":792,"endColumn":95,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[36310,36313],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[36310,36313],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState } from 'react';\r\nimport { useTranslation } from 'react-i18next';\r\nimport {\r\n  AreaChart,\r\n  Area,\r\n  LineChart,\r\n  Line,\r\n  BarChart,\r\n  Bar,\r\n  PieChart,\r\n  Pie,\r\n  Cell,\r\n  XAxis,\r\n  YAxis,\r\n  CartesianGrid,\r\n  Tooltip,\r\n  Legend,\r\n  ResponsiveContainer\r\n} from 'recharts';\r\nimport {\r\n  useCAEvolution,\r\n  useMargesEvolution,\r\n  usePredictions,\r\n  useKPIs,\r\n  useTopProducts,\r\n  useRepartitionCA,\r\n  useAnalyseCategories,\r\n  useAnalyseMarges,\r\n  useAnalyseFournisseurs\r\n} from '../hooks/useFinanceStats';\r\n\r\n// Color palette\r\nconst COLORS = ['#10B981', '#3B82F6', '#F59E0B', '#EF4444', '#8B5CF6', '#EC4899', '#06B6D4', '#84CC16'];\r\n\r\n// Format currency\r\nconst formatMoney = (value: number) => {\r\n  if (value >= 1000000) {\r\n    return `${(value / 1000000).toFixed(1)}M`;\r\n  }\r\n  if (value >= 1000) {\r\n    return `${(value / 1000).toFixed(0)}k`;\r\n  }\r\n  return value.toFixed(0);\r\n};\r\n\r\nconst formatMoneyFull = (value: number) => {\r\n  return new Intl.NumberFormat('fr-FR', { style: 'decimal', maximumFractionDigits: 0 }).format(value) + ' F';\r\n};\r\n\r\nexport default function ModuleFinancier() {\r\n  const { t } = useTranslation();\r\n  const [periode, setPeriode] = useState<'mois' | 'trimestre' | 'annee'>('mois');\r\n  const [critereTop, setCritereTop] = useState<'ca' | 'marge'>('ca');\r\n  const [repartitionBy, setRepartitionBy] = useState<'categorie' | 'fournisseur'>('categorie');\r\n  const [activeChart, setActiveChart] = useState<'ca' | 'marges' | 'predictions'>('ca');\r\n  const [categoryType, setCategoryType] = useState<'rayon' | 'groupe' | 'forme'>('rayon');\r\n\r\n  // Fetch data\r\n  const { data: caEvolution, isLoading: loadingCA } = useCAEvolution();\r\n  const { data: margesData, isLoading: loadingMarges } = useMargesEvolution();\r\n  const { data: predictions, isLoading: loadingPredictions } = usePredictions();\r\n  const { data: kpis, isLoading: loadingKPIs } = useKPIs();\r\n  const { data: topProducts, isLoading: loadingTop } = useTopProducts(periode, critereTop);\r\n  const { data: repartition, isLoading: loadingRepartition } = useRepartitionCA(repartitionBy, periode);\r\n  const { data: categoryAnalysis, isLoading: loadingCategories } = useAnalyseCategories(categoryType, periode);\r\n  const { data: marginAnalysis, isLoading: loadingMarginAnalysis } = useAnalyseMarges();\r\n  const { data: supplierAnalysis, isLoading: loadingSupplierAnalysis } = useAnalyseFournisseurs();\r\n\r\n  // Prepare chart data for CA Evolution\r\n  const caChartData = caEvolution?.labels.map((label, i) => ({\r\n    name: label,\r\n    current: caEvolution.data[i],\r\n    n1: caEvolution.comparaison_n1[i]\r\n  })) || [];\r\n\r\n  // Prepare chart data for Margins\r\n  const margesChartData = margesData?.labels.map((label, i) => ({\r\n    name: label,\r\n    marge: margesData.marge_brute[i],\r\n    taux: margesData.taux_marge[i]\r\n  })) || [];\r\n\r\n  // Prepare predictions chart data\r\n  const predictionsChartData = [\r\n    ...(predictions?.labels.map((label, i) => ({\r\n      name: label,\r\n      historique: predictions.historique[i],\r\n      prediction: null as number | null\r\n    })) || []),\r\n    ...(predictions?.prediction_labels.map((label, i) => ({\r\n      name: label,\r\n      historique: null as number | null,\r\n      prediction: predictions.predictions[i]\r\n    })) || [])\r\n  ];\r\n\r\n  // Get trend icon and color\r\n  const getTrendInfo = (tendance: string) => {\r\n    switch (tendance) {\r\n      case 'hausse':\r\n        return { icon: '­ƒôê', color: 'text-green-500', label: t('finance.trend.up', 'En hausse') };\r\n      case 'baisse':\r\n        return { icon: '­ƒôë', color: 'text-red-500', label: t('finance.trend.down', 'En baisse') };\r\n      default:\r\n        return { icon: 'Ô×í´©Å', color: 'text-yellow-500', label: t('finance.trend.stable', 'Stable') };\r\n    }\r\n  };\r\n\r\n  const trendInfo = predictions ? getTrendInfo(predictions.tendance) : null;\r\n\r\n  return (\r\n    <div className=\"p-6 space-y-6\">\r\n      {/* Header */}\r\n      <div className=\"flex flex-col md:flex-row md:items-center md:justify-between gap-4\">\r\n        <div>\r\n          <h1 className=\"text-2xl font-bold text-base-content\">\r\n            {t('finance.title', 'Module Financier')}\r\n          </h1>\r\n          <p className=\"text-base-content/60\">\r\n            {t('finance.subtitle', 'Analyse et pr├®dictions du chiffre d\\'affaires')}\r\n          </p>\r\n        </div>\r\n        <div className=\"flex gap-2\">\r\n          <select \r\n            className=\"select select-bordered select-sm\"\r\n            value={periode}\r\n            onChange={(e) => setPeriode(e.target.value as 'mois' | 'trimestre' | 'annee')}\r\n          >\r\n            <option value=\"mois\">{t('finance.periode.mois', 'Ce mois')}</option>\r\n            <option value=\"trimestre\">{t('finance.periode.trimestre', 'Ce trimestre')}</option>\r\n            <option value=\"annee\">{t('finance.periode.annee', 'Cette ann├®e')}</option>\r\n          </select>\r\n        </div>\r\n      </div>\r\n\r\n      {/* KPIs Cards */}\r\n      {loadingKPIs ? (\r\n        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4\">\r\n          {[1, 2, 3, 4].map((i) => (\r\n            <div key={i} className=\"card bg-base-100 shadow-lg animate-pulse h-32\"></div>\r\n          ))}\r\n        </div>\r\n      ) : kpis && (\r\n        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4\">\r\n          {/* Panier Moyen */}\r\n          <div className=\"card bg-gradient-to-br from-green-500 to-green-600 text-white shadow-lg\">\r\n            <div className=\"card-body p-4\">\r\n              <h3 className=\"text-sm font-medium opacity-80\">\r\n                {t('finance.kpis.avg_basket', 'Panier Moyen')}\r\n              </h3>\r\n              <p className=\"text-3xl font-bold\">{formatMoneyFull(kpis.panier_moyen.mois)}</p>\r\n              <p className=\"text-xs opacity-70\">\r\n                Annuel: {formatMoneyFull(kpis.panier_moyen.annee)}\r\n              </p>\r\n            </div>\r\n          </div>\r\n\r\n          {/* Taux de Marge */}\r\n          <div className=\"card bg-gradient-to-br from-blue-500 to-blue-600 text-white shadow-lg\">\r\n            <div className=\"card-body p-4\">\r\n              <h3 className=\"text-sm font-medium opacity-80\">\r\n                {t('finance.kpis.margin_rate', 'Taux de Marge')}\r\n              </h3>\r\n              <p className=\"text-3xl font-bold\">{kpis.taux_marge}%</p>\r\n              <p className=\"text-xs opacity-70\">\r\n                {kpis.nb_ventes_mois} ventes ce mois\r\n              </p>\r\n            </div>\r\n          </div>\r\n\r\n          {/* DSI */}\r\n          <div className=\"card bg-gradient-to-br from-purple-500 to-purple-600 text-white shadow-lg\">\r\n            <div className=\"card-body p-4\">\r\n              <h3 className=\"text-sm font-medium opacity-80\">\r\n                {t('finance.kpis.dsi', 'Jours Stock (DSI)')}\r\n              </h3>\r\n              <p className=\"text-3xl font-bold\">{kpis.dsi} j</p>\r\n              <p className=\"text-xs opacity-70\">\r\n                Stock: {formatMoneyFull(kpis.stock_value)}\r\n              </p>\r\n            </div>\r\n          </div>\r\n\r\n          {/* Croissance */}\r\n          <div className={`card shadow-lg ${kpis.croissance_mensuelle >= 0 \r\n            ? 'bg-gradient-to-br from-emerald-500 to-emerald-600' \r\n            : 'bg-gradient-to-br from-red-500 to-red-600'} text-white`}>\r\n            <div className=\"card-body p-4\">\r\n              <h3 className=\"text-sm font-medium opacity-80\">\r\n                {t('finance.kpis.growth', 'Croissance Mensuelle')}\r\n              </h3>\r\n              <p className=\"text-3xl font-bold\">\r\n                {kpis.croissance_mensuelle >= 0 ? '+' : ''}{kpis.croissance_mensuelle}%\r\n              </p>\r\n              <p className=\"text-xs opacity-70\">\r\n                CA: {formatMoneyFull(kpis.ca_mois)}\r\n              </p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      )}\r\n\r\n      {/* Main Charts */}\r\n      <div className=\"card bg-base-100 shadow-lg\">\r\n        <div className=\"card-body\">\r\n          {/* Chart Tabs */}\r\n          <div className=\"tabs tabs-boxed mb-4 w-fit\">\r\n            <button \r\n              className={`tab ${activeChart === 'ca' ? 'tab-active' : ''}`}\r\n              onClick={() => setActiveChart('ca')}\r\n            >\r\n              {t('finance.charts.ca_evolution', '├ëvolution CA')}\r\n            </button>\r\n            <button \r\n              className={`tab ${activeChart === 'marges' ? 'tab-active' : ''}`}\r\n              onClick={() => setActiveChart('marges')}\r\n            >\r\n              {t('finance.charts.margins', 'Marges')}\r\n            </button>\r\n            <button \r\n              className={`tab ${activeChart === 'predictions' ? 'tab-active' : ''}`}\r\n              onClick={() => setActiveChart('predictions')}\r\n            >\r\n              {t('finance.charts.predictions', 'Pr├®dictions')} {trendInfo && <span className=\"ml-1\">{trendInfo.icon}</span>}\r\n            </button>\r\n          </div>\r\n\r\n          {/* CA Evolution Chart */}\r\n          {activeChart === 'ca' && (\r\n            <div>\r\n              <div className=\"flex items-center justify-between mb-4\">\r\n                <h3 className=\"text-lg font-semibold\">\r\n                  {t('finance.charts.ca_12_months', 'Chiffre d\\'Affaires (12 derniers mois)')}\r\n                </h3>\r\n                {caEvolution && (\r\n                  <div className={`badge ${caEvolution.croissance_yoy >= 0 ? 'badge-success' : 'badge-error'} badge-lg`}>\r\n                    {caEvolution.croissance_yoy >= 0 ? '+' : ''}{caEvolution.croissance_yoy}% vs N-1\r\n                  </div>\r\n                )}\r\n              </div>\r\n              {loadingCA ? (\r\n                <div className=\"h-80 flex items-center justify-center\">\r\n                  <span className=\"loading loading-spinner loading-lg\"></span>\r\n                </div>\r\n              ) : (\r\n                <ResponsiveContainer width=\"100%\" height={350}>\r\n                  <AreaChart data={caChartData}>\r\n                    <defs>\r\n                      <linearGradient id=\"colorCurrent\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\r\n                        <stop offset=\"5%\" stopColor=\"#10B981\" stopOpacity={0.3}/>\r\n                        <stop offset=\"95%\" stopColor=\"#10B981\" stopOpacity={0}/>\r\n                      </linearGradient>\r\n                    </defs>\r\n                    <CartesianGrid strokeDasharray=\"3 3\" opacity={0.3} />\r\n                    <XAxis dataKey=\"name\" fontSize={12} />\r\n                    <YAxis tickFormatter={formatMoney} fontSize={12} />\r\n                    <Tooltip formatter={(value: number) => formatMoneyFull(value)} />\r\n                    <Legend />\r\n                    <Area \r\n                      type=\"monotone\" \r\n                      dataKey=\"current\" \r\n                      name={t('finance.charts.current_revenue', 'CA Actuel')}\r\n                      stroke=\"#10B981\" \r\n                      fillOpacity={1} \r\n                      fill=\"url(#colorCurrent)\" \r\n                      strokeWidth={2}\r\n                    />\r\n                    <Line \r\n                      type=\"monotone\" \r\n                      dataKey=\"n1\" \r\n                      name={t('finance.charts.n1_revenue', 'CA N-1')}\r\n                      stroke=\"#6B7280\" \r\n                      strokeDasharray=\"5 5\" \r\n                      dot={false}\r\n                    />\r\n                  </AreaChart>\r\n                </ResponsiveContainer>\r\n              )}\r\n            </div>\r\n          )}\r\n\r\n          {/* Margins Chart */}\r\n          {activeChart === 'marges' && (\r\n            <div>\r\n              <div className=\"flex items-center justify-between mb-4\">\r\n                <h3 className=\"text-lg font-semibold\">\r\n                  {t('finance.charts.margin_evolution', '├ëvolution des Marges')}\r\n                </h3>\r\n                {margesData && (\r\n                  <div className=\"badge badge-primary badge-lg\">\r\n                    Taux moyen: {margesData.taux_moyen}%\r\n                  </div>\r\n                )}\r\n              </div>\r\n              {loadingMarges ? (\r\n                <div className=\"h-80 flex items-center justify-center\">\r\n                  <span className=\"loading loading-spinner loading-lg\"></span>\r\n                </div>\r\n              ) : (\r\n                <ResponsiveContainer width=\"100%\" height={350}>\r\n                  <BarChart data={margesChartData}>\r\n                    <CartesianGrid strokeDasharray=\"3 3\" opacity={0.3} />\r\n                    <XAxis dataKey=\"name\" fontSize={12} />\r\n                    <YAxis yAxisId=\"left\" tickFormatter={formatMoney} fontSize={12} />\r\n                    <YAxis yAxisId=\"right\" orientation=\"right\" unit=\"%\" fontSize={12} />\r\n                    <Tooltip formatter={(value: number, name: string) => \r\n                      name === 'taux' ? `${value}%` : formatMoneyFull(value)\r\n                    } />\r\n                    <Legend />\r\n                    <Bar yAxisId=\"left\" dataKey=\"marge\" name={t('finance.margin', 'Marge Brute')} fill=\"#3B82F6\" radius={[4, 4, 0, 0]} />\r\n                    <Line yAxisId=\"right\" type=\"monotone\" dataKey=\"taux\" name={t('finance.margin_rate', 'Taux %')} stroke=\"#F59E0B\" strokeWidth={2} />\r\n                  </BarChart>\r\n                </ResponsiveContainer>\r\n              )}\r\n            </div>\r\n          )}\r\n\r\n          {/* Predictions Chart */}\r\n          {activeChart === 'predictions' && (\r\n            <div>\r\n              <div className=\"flex items-center justify-between mb-4\">\r\n                <h3 className=\"text-lg font-semibold\">\r\n                  {t('finance.charts.predictions_3m', 'Pr├®dictions CA (3 prochains mois)')}\r\n                </h3>\r\n                {predictions && (\r\n                  <div className=\"flex items-center gap-2\">\r\n                    <span className={`badge ${\r\n                      predictions.confiance === 'haute' ? 'badge-success' :\r\n                      predictions.confiance === 'moyenne' ? 'badge-warning' : 'badge-error'\r\n                    }`}>\r\n                      Confiance: {predictions.confiance}\r\n                    </span>\r\n                    <span className={`font-medium ${trendInfo?.color}`}>\r\n                      {trendInfo?.icon} {trendInfo?.label}\r\n                    </span>\r\n                  </div>\r\n                )}\r\n              </div>\r\n              {loadingPredictions ? (\r\n                <div className=\"h-80 flex items-center justify-center\">\r\n                  <span className=\"loading loading-spinner loading-lg\"></span>\r\n                </div>\r\n              ) : (\r\n                <ResponsiveContainer width=\"100%\" height={350}>\r\n                  <LineChart data={predictionsChartData}>\r\n                    <CartesianGrid strokeDasharray=\"3 3\" opacity={0.3} />\r\n                    <XAxis dataKey=\"name\" fontSize={12} />\r\n                    <YAxis tickFormatter={formatMoney} fontSize={12} />\r\n                    <Tooltip formatter={(value: number) => value ? formatMoneyFull(value) : '-'} />\r\n                    <Legend />\r\n                    <Line \r\n                      type=\"monotone\" \r\n                      dataKey=\"historique\" \r\n                      name={t('finance.charts.history', 'Historique')}\r\n                      stroke=\"#10B981\" \r\n                      strokeWidth={2}\r\n                      dot={{ fill: '#10B981' }}\r\n                      connectNulls={false}\r\n                    />\r\n                    <Line \r\n                      type=\"monotone\" \r\n                      dataKey=\"prediction\" \r\n                      name={t('finance.charts.prediction', 'Pr├®diction')}\r\n                      stroke=\"#8B5CF6\" \r\n                      strokeWidth={2}\r\n                      strokeDasharray=\"5 5\"\r\n                      dot={{ fill: '#8B5CF6' }}\r\n                      connectNulls={false}\r\n                    />\r\n                  </LineChart>\r\n                </ResponsiveContainer>\r\n              )}\r\n            </div>\r\n          )}\r\n        </div>\r\n      </div>\r\n\r\n      {/* Bottom Section: Repartition + Top Products */}\r\n      <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-6\">\r\n        {/* Repartition CA */}\r\n        <div className=\"card bg-base-100 shadow-lg\">\r\n          <div className=\"card-body\">\r\n            <div className=\"flex items-center justify-between mb-4\">\r\n              <h3 className=\"text-lg font-semibold\">\r\n                {t('finance.charts.repartition', 'R├®partition CA')}\r\n              </h3>\r\n              <select \r\n                className=\"select select-bordered select-sm\"\r\n                value={repartitionBy}\r\n                onChange={(e) => setRepartitionBy(e.target.value as 'categorie' | 'fournisseur')}\r\n              >\r\n                <option value=\"categorie\">{t('finance.by_category', 'Par Cat├®gorie')}</option>\r\n                <option value=\"fournisseur\">{t('finance.by_supplier', 'Par Fournisseur')}</option>\r\n              </select>\r\n            </div>\r\n            {loadingRepartition ? (\r\n              <div className=\"h-64 flex items-center justify-center\">\r\n                <span className=\"loading loading-spinner loading-lg\"></span>\r\n              </div>\r\n            ) : repartition && repartition.data.length > 0 ? (\r\n              <ResponsiveContainer width=\"100%\" height={280}>\r\n                <PieChart>\r\n                  <Pie\r\n                    data={repartition.data.map(item => ({ ...item, name: item.nom }))}\r\n                    cx=\"50%\"\r\n                    cy=\"50%\"\r\n                    labelLine={false}\r\n                    outerRadius={100}\r\n                    fill=\"#8884d8\"\r\n                    dataKey=\"ca\"\r\n                    nameKey=\"name\"\r\n                    label={({ name, percent }) => \r\n                      `${String(name || '').substring(0, 10)}... ${((percent || 0) * 100).toFixed(0)}%`\r\n                    }\r\n                  >\r\n                    {repartition.data.map((_, index) => (\r\n                      <Cell key={`cell-${index}`} fill={COLORS[index % COLORS.length]} />\r\n                    ))}\r\n                  </Pie>\r\n                  <Tooltip formatter={(value: number) => formatMoneyFull(value)} />\r\n                </PieChart>\r\n              </ResponsiveContainer>\r\n            ) : (\r\n              <div className=\"h-64 flex items-center justify-center text-base-content/50\">\r\n                {t('common.no_data', 'Aucune donn├®e')}\r\n              </div>\r\n            )}\r\n          </div>\r\n        </div>\r\n\r\n        {/* Top Products */}\r\n        <div className=\"card bg-base-100 shadow-lg\">\r\n          <div className=\"card-body\">\r\n            <div className=\"flex items-center justify-between mb-4\">\r\n              <h3 className=\"text-lg font-semibold\">\r\n                {t('finance.top_products', 'Top Produits')}\r\n              </h3>\r\n              <select \r\n                className=\"select select-bordered select-sm\"\r\n                value={critereTop}\r\n                onChange={(e) => setCritereTop(e.target.value as 'ca' | 'marge')}\r\n              >\r\n                <option value=\"ca\">{t('finance.by_revenue', 'Par CA')}</option>\r\n                <option value=\"marge\">{t('finance.by_margin', 'Par Marge')}</option>\r\n              </select>\r\n            </div>\r\n            {loadingTop ? (\r\n              <div className=\"h-64 flex items-center justify-center\">\r\n                <span className=\"loading loading-spinner loading-lg\"></span>\r\n              </div>\r\n            ) : topProducts && topProducts.data.length > 0 ? (\r\n              <div className=\"overflow-x-auto max-h-72\">\r\n                <table className=\"table table-sm table-zebra\">\r\n                  <thead>\r\n                    <tr>\r\n                      <th>#</th>\r\n                      <th>{t('finance.product', 'Produit')}</th>\r\n                      <th className=\"text-right\">CA</th>\r\n                      <th className=\"text-right\">{t('finance.margin', 'Marge')}</th>\r\n                      <th className=\"text-right\">%</th>\r\n                    </tr>\r\n                  </thead>\r\n                  <tbody>\r\n                    {topProducts.data.map((product, index) => (\r\n                      <tr key={product.id}>\r\n                        <td className=\"font-bold text-primary\">{index + 1}</td>\r\n                        <td className=\"max-w-[150px] truncate\" title={product.nom}>\r\n                          {product.nom}\r\n                        </td>\r\n                        <td className=\"text-right font-mono\">{formatMoneyFull(product.ca)}</td>\r\n                        <td className=\"text-right font-mono text-success\">{formatMoneyFull(product.marge)}</td>\r\n                        <td className=\"text-right\">{product.taux_marge}%</td>\r\n                      </tr>\r\n                    ))}\r\n                  </tbody>\r\n                </table>\r\n              </div>\r\n            ) : (\r\n              <div className=\"h-64 flex items-center justify-center text-base-content/50\">\r\n                {t('common.no_data', 'Aucune donn├®e')}\r\n              </div>\r\n            )}\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      {/* Category Analysis Section */}\r\n      <div className=\"card bg-base-100 shadow-lg\">\r\n        <div className=\"card-body\">\r\n          <div className=\"flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-4\">\r\n            <h3 className=\"text-lg font-semibold\">\r\n              {t('finance.category_analysis', 'Analyse par Cat├®gorie')}\r\n            </h3>\r\n            <div className=\"flex gap-2\">\r\n              <div className=\"btn-group\">\r\n                <button\r\n                  className={`btn btn-sm ${categoryType === 'rayon' ? 'btn-primary' : 'btn-ghost'}`}\r\n                  onClick={() => setCategoryType('rayon')}\r\n                >\r\n                  {t('finance.category.rayon', 'Rayon')}\r\n                </button>\r\n                <button\r\n                  className={`btn btn-sm ${categoryType === 'groupe' ? 'btn-primary' : 'btn-ghost'}`}\r\n                  onClick={() => setCategoryType('groupe')}\r\n                >\r\n                  {t('finance.category.groupe', 'Groupe')}\r\n                </button>\r\n                <button\r\n                  className={`btn btn-sm ${categoryType === 'forme' ? 'btn-primary' : 'btn-ghost'}`}\r\n                  onClick={() => setCategoryType('forme')}\r\n                >\r\n                  {t('finance.category.forme', 'Forme')}\r\n                </button>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          \r\n          {loadingCategories ? (\r\n            <div className=\"h-64 flex items-center justify-center\">\r\n              <span className=\"loading loading-spinner loading-lg\"></span>\r\n            </div>\r\n          ) : categoryAnalysis && categoryAnalysis.data.length > 0 ? (\r\n            <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-6\">\r\n              {/* Bar Chart */}\r\n              <div>\r\n                <ResponsiveContainer width=\"100%\" height={300}>\r\n                  <BarChart data={categoryAnalysis.data.slice(0, 10)} layout=\"vertical\">\r\n                    <CartesianGrid strokeDasharray=\"3 3\" stroke=\"#374151\" />\r\n                    <XAxis type=\"number\" tickFormatter={(v) => formatMoney(v)} />\r\n                    <YAxis \r\n                      type=\"category\" \r\n                      dataKey=\"nom\" \r\n                      width={120} \r\n                      tick={{ fontSize: 11 }}\r\n                    />\r\n                    <Tooltip formatter={(value: number) => formatMoneyFull(value)} />\r\n                    <Bar dataKey=\"ca\" fill=\"#3B82F6\" name=\"CA\" />\r\n                    <Bar dataKey=\"marge\" fill=\"#10B981\" name=\"Marge\" />\r\n                  </BarChart>\r\n                </ResponsiveContainer>\r\n              </div>\r\n              \r\n              {/* Table */}\r\n              <div className=\"overflow-x-auto max-h-80\">\r\n                <table className=\"table table-sm table-zebra\">\r\n                  <thead className=\"sticky top-0 z-10 bg-base-100 opacity-100\">\r\n                    <tr>\r\n                      <th>{categoryType === 'rayon' ? t('finance.category.rayon', 'Rayon') : categoryType === 'groupe' ? t('finance.category.groupe', 'Groupe') : t('finance.category.forme', 'Forme')}</th>\r\n                      <th className=\"text-right\">CA</th>\r\n                      <th className=\"text-right\">{t('finance.margin', 'Marge')}</th>\r\n                      <th className=\"text-right\">{t('finance.margin_rate', 'Taux')}</th>\r\n                      <th className=\"text-right\">%</th>\r\n                    </tr>\r\n                  </thead>\r\n                  <tbody>\r\n                    {categoryAnalysis.data.map((item) => (\r\n                      <tr key={item.id}>\r\n                        <td className=\"max-w-[150px] truncate\" title={item.nom}>\r\n                          {item.nom}\r\n                        </td>\r\n                        <td className=\"text-right font-mono\">{formatMoneyFull(item.ca)}</td>\r\n                        <td className=\"text-right font-mono text-success\">{formatMoneyFull(item.marge)}</td>\r\n                        <td className=\"text-right\">{item.taux_marge}%</td>\r\n                        <td className=\"text-right\">\r\n                          <span className=\"badge badge-primary badge-sm\">{item.pourcentage_ca}%</span>\r\n                        </td>\r\n                      </tr>\r\n                    ))}\r\n                  </tbody>\r\n                </table>\r\n              </div>\r\n            </div>\r\n          ) : (\r\n            <div className=\"h-64 flex items-center justify-center text-base-content/50\">\r\n              {t('finance.category.no_data', 'Aucune donn├®e pour cette cat├®gorie')}\r\n            </div>\r\n          )}\r\n          \r\n          {/* Category Summary */}\r\n          {categoryAnalysis && (\r\n            <div className=\"mt-4 flex gap-4 flex-wrap\">\r\n              <div className=\"stat bg-base-200 rounded-lg p-3\">\r\n                <div className=\"stat-title text-xs\">{t('finance.category.total_ca', 'CA Total')}</div>\r\n                <div className=\"stat-value text-lg text-primary\">{formatMoneyFull(categoryAnalysis.total_ca)}</div>\r\n              </div>\r\n              <div className=\"stat bg-base-200 rounded-lg p-3\">\r\n                <div className=\"stat-title text-xs\">{t('finance.category.total_margin', 'Marge Totale')}</div>\r\n                <div className=\"stat-value text-lg text-success\">{formatMoneyFull(categoryAnalysis.total_marge)}</div>\r\n              </div>\r\n              <div className=\"stat bg-base-200 rounded-lg p-3\">\r\n                <div className=\"stat-title text-xs\">{t('finance.category.global_rate', 'Taux Marge Global')}</div>\r\n                <div className=\"stat-value text-lg\">{categoryAnalysis.taux_marge_global}%</div>\r\n              </div>\r\n            </div>\r\n          )}\r\n        </div>\r\n      </div>\r\n\r\n\r\n\r\n      {/* Margin Analysis Section */}\r\n      <div className=\"card bg-base-100 shadow-lg\">\r\n        <div className=\"card-body\">\r\n          <h3 className=\"text-lg font-semibold mb-4\">\r\n            {t('finance.margin_analysis', 'Analyse Avanc├®e et Opportunit├®s')}\r\n          </h3>\r\n          \r\n          {loadingMarginAnalysis ? (\r\n            <div className=\"h-48 flex items-center justify-center\">\r\n              <span className=\"loading loading-spinner loading-lg\"></span>\r\n            </div>\r\n          ) : marginAnalysis ? (\r\n            <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\r\n              \r\n              {/* Opportunit├®s Moyenne Marge */}\r\n              <div className=\"card bg-base-200\">\r\n                <div className=\"card-body p-4\">\r\n                  <h4 className=\"card-title text-sm flex items-center gap-2\">\r\n                    <span className=\"text-warning\">ÔÜá´©Å</span>\r\n                    {t('finance.analysis.opportunities', 'Faible Marge / Fort Volume')}\r\n                  </h4>\r\n                  <p className=\"text-xs opacity-70 mb-2\">\r\n                    {t('finance.analysis.negotiation', 'Opportunit├®s de n├®gociation fournisseur')}\r\n                  </p>\r\n                  \r\n                  <div className=\"overflow-x-auto max-h-60\">\r\n                    <table className=\"table table-xs\">\r\n                      <thead>\r\n                        <tr>\r\n                          <th>{t('finance.product', 'Produit')}</th>\r\n                          <th className=\"text-right\">{t('finance.margin', 'Marge')}</th>\r\n                          <th className=\"text-right\">{t('finance.analysis.gain', 'Gain Pot.')}</th>\r\n                        </tr>\r\n                      </thead>\r\n                      <tbody>\r\n                        {marginAnalysis.opportunites_nego.length > 0 ? (\r\n                          marginAnalysis.opportunites_nego.map((item) => (\r\n                            <tr key={item.id}>\r\n                              <td className=\"max-w-[120px] truncate\" title={item.nom}>\r\n                                {item.nom}\r\n                              </td>\r\n                              <td className=\"text-right text-warning font-bold\">\r\n                                {item.taux_marge}%\r\n                              </td>\r\n                              <td className=\"text-right text-success\">\r\n                                +{formatMoney(item.marge_perdue)}\r\n                              </td>\r\n                            </tr>\r\n                          ))\r\n                        ) : (\r\n                          <tr><td colSpan={3} className=\"text-center opacity-50\">{t('finance.analysis.no_opportunity', 'Aucune opportunit├® d├®tect├®e')}</td></tr>\r\n                        )}\r\n                      </tbody>\r\n                    </table>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n\r\n              {/* Stock Dormant */}\r\n              <div className=\"card bg-base-200\">\r\n                <div className=\"card-body p-4\">\r\n                  <h4 className=\"card-title text-sm flex items-center gap-2\">\r\n                    <span className=\"text-error\">­ƒøæ</span>\r\n                    {t('finance.analysis.dormant', 'Forte Marge / Faible Rotation')}\r\n                  </h4>\r\n                  <p className=\"text-xs opacity-70 mb-2\">\r\n                    {t('finance.analysis.dormant_risk', 'Risque de stock dormant (Argent immobilis├®)')}\r\n                  </p>\r\n                  \r\n                  <div className=\"overflow-x-auto max-h-60\">\r\n                    <table className=\"table table-xs\">\r\n                      <thead>\r\n                        <tr>\r\n                          <th>{t('finance.product', 'Produit')}</th>\r\n                          <th className=\"text-right\">{t('finance.margin', 'Marge')}</th>\r\n                          <th className=\"text-right\">{t('finance.analysis.price', 'Prix')}</th>\r\n                        </tr>\r\n                      </thead>\r\n                      <tbody>\r\n                        {marginAnalysis.stock_dormant.length > 0 ? (\r\n                          marginAnalysis.stock_dormant.map((item) => (\r\n                            <tr key={item.id}>\r\n                              <td className=\"max-w-[120px] truncate\" title={item.nom}>\r\n                                {item.nom}\r\n                              </td>\r\n                              <td className=\"text-right text-success font-bold\">\r\n                                {item.taux_marge}%\r\n                              </td>\r\n                              <td className=\"text-right\">\r\n                                {formatMoney(item.prix_actuel)}\r\n                              </td>\r\n                            </tr>\r\n                          ))\r\n                        ) : (\r\n                          <tr><td colSpan={3} className=\"text-center opacity-50\">{t('finance.analysis.no_dormant', 'Aucun produit dormant d├®tect├®')}</td></tr>\r\n                        )}\r\n                      </tbody>\r\n                    </table>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n\r\n              {/* Suggestions Prix */}\r\n              <div className=\"card bg-base-200\">\r\n                <div className=\"card-body p-4\">\r\n                  <h4 className=\"card-title text-sm flex items-center gap-2\">\r\n                    <span className=\"text-success\">­ƒÆí</span>\r\n                    {t('finance.analysis.price_opt', 'Optimisation Prix (+5%)')}\r\n                  </h4>\r\n                  <p className=\"text-xs opacity-70 mb-2\">\r\n                    {t('finance.analysis.low_margin_impact', 'Produits ├á marge tr├¿s faible (Impact estim├®)')}\r\n                  </p>\r\n                  \r\n                  <div className=\"overflow-x-auto max-h-60\">\r\n                    <table className=\"table table-xs\">\r\n                      <thead>\r\n                        <tr>\r\n                          <th>{t('finance.product', 'Produit')}</th>\r\n                          <th className=