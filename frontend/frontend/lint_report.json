is.status_ann', 'Annul├®s')}</option>\r\n                        </select>\r\n                    </div>\r\n                </div>\r\n\r\n                <div className=\"flex items-center gap-2 w-full md:w-auto justify-end\">\r\n                    <button \r\n                        className=\"btn btn-square btn-ghost text-base-content/60 hover:text-primary hover:bg-primary/10 transition-colors\"\r\n                        onClick={onRefresh}\r\n                        title={t('common.refresh', 'Actualiser')}\r\n                    >\r\n                        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\" strokeLinecap=\"round\" strokeLinejoin=\"round\"><path d=\"M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8\"/><path d=\"M3 3v5h5\"/></svg>\r\n                    </button>\r\n                    <button \r\n                        className=\"btn btn-primary gap-2 text-white shadow-sm hover:shadow-md transition-all\"\r\n                        onClick={onNew}\r\n                    >\r\n                        <Plus className=\"w-4 h-4\" />\r\n                        <span className=\"hidden sm:inline\">{t('promis.new_btn', 'Nouveau Promis')}</span>\r\n                        <span className=\"sm:hidden\">{t('common.add', 'Ajouter')}</span>\r\n                    </button>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    );\r\n};\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Projet Fullstack\\fullstack_produits\\frontend\\frontend\\src\\components\\promis\\PromisQuickStats.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Projet Fullstack\\fullstack_produits\\frontend\\frontend\\src\\components\\promis\\PromisTable.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCou