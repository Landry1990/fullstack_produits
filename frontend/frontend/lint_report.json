leChange('ticket_footer_message', e.target.value)}\r\n                  className=\"textarea textarea-bordered w-full\"\r\n                  rows={2}\r\n                  placeholder=\"Merci de votre visite! ├Ç bient├┤t.\"\r\n                />\r\n                <label className=\"label\">\r\n                  <span className=\"label-text-alt text-base-content/50\">Message de remerciement affich├® en bas du ticket</span>\r\n                </label>\r\n              </div>\r\n            </div>\r\n          </div>\r\n\r\n          {/* Section: Param├¿tres Syst├¿me & Alertes */}\r\n          <div className=\"bg-white rounded-xl shadow-sm border border-base-200 overflow-hidden\">\r\n            <div className=\"bg-base-100 px-6 py-4 border-b border-base-200\">\r\n              <h2 className=\"font-semibold text-lg flex items-center gap-2\">\r\n                <svg xmlns=\"http://www.w3.org/2000/svg\" className=\"h-5 w-5 text-primary\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\r\n                  <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth=\"2\" d=\"M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z\" />\r\n                  <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth=\"2\" d=\"M15 12a3 3 0 11-6 0 3 3 0 016 0z\" />\r\n                </svg>\r\n                Param├¿tres Syst├¿me & Alertes\r\n              </h2>\r\n            </div>\r\n            <div className=\"p-6 space-y-4\">\r\n              \r\n              <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\r\n                 <div className=\"form-control\">\r\n                  <label className=\"label\">\r\n                    <span className=\"label-text font-medium\">Largeur Ticket (mm)</span>\r\n                  </label>\r\n                  <select\r\n                    value={formData.ticket_paper_width || 80}\r\n                    onChange={(e) => handleChange('ticket_paper_width', parseInt(e.target.value) as any)}\r\n                    className=\"select select-bordered w-full\"\r\n                  >\r\n                    <option value={80}>80mm (Standard)</option>\r\n                    <option value={58}>58mm (Petit)</option>\r\n                  </select>\r\n                </div>\r\n                <div className=\"form-control\">\r\n                  <label className=\"label\">\r\n                    <span className=\"label-text font-medium\">Devise</span>\r\n                  </label>\r\n                  <input\r\n                    type=\"text\"\r\n                    value={formData.currency_symbol || 'FCFA'}\r\n                    onChange={(e) => handleChange('currency_symbol', e.target.value)}\r\n                    className=\"input input-bordered w-full\"\r\n                    placeholder=\"ex: FCFA, Ôé¼, $\"\r\n                  />\r\n                </div>\r\n              </div>\r\n\r\n               <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\r\n                 <div className=\"form-control\">\r\n                  <label className=\"label\">\r\n                    <span className=\"label-text font-medium\">Seuil Stock Bas (Jours)</span>\r\n                  </label>\r\n                  <input\r\n                    type=\"number\"\r\n                    value={formData.low_stock_threshold_days || 15}\r\n                    onChange={(e) => handleChange('low_stock_threshold_days', parseInt(e.target.value) as any)}\r\n                    className=\"input input-bordered w-full\"\r\n                  />\r\n                  <label className=\"label\">\r\n                    <span className=\"label-text-alt text-base-content/50\">Alerte si couverture inf├®rieure ├á ce nombre</span>\r\n                  </label>\r\n                </div>\r\n                <div className=\"form-control\">\r\n                  <label className=\"label\">\r\n                    <span className=\"label-text font-medium\">Seuil Stock Dormant (Jours)</span>\r\n                  </label>\r\n                  <input\r\n                    type=\"number\"\r\n                    value={formData.dormant_stock_days || 90}\r\n                    onChange={(e) => handleChange('dormant_stock_days', parseInt(e.target.value) as any)}\r\n                    className=\"input input-bordered w-full\"\r\n                  />\r\n                  <label className=\"label\">\r\n                    <span className=\"label-text-alt text-base-content/50\">Alerte si aucune vente depuis ce nombre de jours</span>\r\n                  </label>\r\n                </div>\r\n              </div>\r\n\r\n              <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\r\n                  <div className=\"form-control\">\r\n                      <label className=\"label\">\r\n                        <span className=\"label-text font-medium\">Seuil Alerte Dette Client</span>\r\n                      </label>\r\n                      <input\r\n                        type=\"number\"\r\n                        value={formData.debt_alert_threshold || '100000'}\r\n                        onChange={(e) => handleChange('debt_alert_threshold', e.target.value)}\r\n                        className=\"input input-bordered w-full\"\r\n                      />\r\n                      <label className=\"label\">\r\n                        <span className=\"label-text-alt text-base-content/50\">Montant de dette ├á partir duquel une alerte est lev├®e</span>\r\n                      </label>\r\n                  </div>\r\n                  \r\n                  <div className=\"form-control\">\r\n                      <label className=\"label\">\r\n                        <span className=\"label-text font-medium\">D├®connexion Automatique (minutes)</span>\r\n                      </label>\r\n                      <input\r\n                        type=\"number\"\r\n                        min=\"0\"\r\n                        value={formData.auto_logout_timeout !== undefined ? formData.auto_logout_timeout : 15}\r\n                        onChange={(e) => handleChange('auto_logout_timeout', parseInt(e.target.value) || 0)}\r\n                        className=\"input input-bordered w-full\"\r\n                      />\r\n                      <label className=\"label\">\r\n                        <span className=\"label-text-alt text-base-content/50\">Temps d'inactivit├® avant d├®connexion (Mettre 0 pour d├®sactiver)</span>\r\n                      </label>\r\n                  </div>\r\n              </div>\r\n\r\n            </div>\r\n          </div>\r\n\r\n          {/* Section: Gestion de la TVA */}\r\n\r\n          {/* Section: Gestion de la TVA */}\r\n          <div className=\"bg-white rounded-xl shadow-sm border border-base-200 overflow-hidden\">\r\n            <div className=\"bg-base-100 px-6 py-4 border-b border-base-200\">\r\n              <h2 className=\"font-semibold text-lg flex items-center gap-2\">\r\n                <svg xmlns=\"http://www.w3.org/2000/svg\" className=\"h-5 w-5 text-primary\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\r\n                  <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth=\"2\" d=\"M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z\" />\r\n                </svg>\r\n                Gestion de la TVA\r\n              </h2>\r\n            </div>\r\n            <div className=\"p-6 space-y-6\">\r\n              <div className=\"overflow-x-auto\">\r\n                <table className=\"table\">\r\n                  <thead>\r\n                    <tr>\r\n                      <th>Taux (%)</th>\r\n                      <th>Libell├®</th>\r\n                      <th>Statut</th>\r\n                      <th className=\"text-right\">Actions</th>\r\n                    </tr>\r\n                  </thead>\r\n                  <tbody>\r\n                    {loadingTVA ? (\r\n                      <tr><td colSpan={4} className=\"text-center\">Chargement...</td></tr>\r\n                    ) : !Array.isArray(tvaList) || tvaList.length === 0 ? (\r\n                      <tr><td colSpan={4} className=\"text-center text-base-content/60\">Aucun taux configur├®</td></tr>\r\n                    ) : (\r\n                      tvaList.map(tva => (\r\n                        <tr key={tva.id}>\r\n                          <td className=\"font-bold\">{tva.taux}%</td>\r\n                          <td>{tva.libelle || '-'}</td>\r\n                          <td>\r\n                            {tva.is_active ? \r\n                              <span className=\"badge badge-success badge-sm\">Actif</span> : \r\n                              <span className=\"badge badge-ghost badge-sm\">Inactif</span>\r\n                            }\r\n                          </td>\r\n                          <td className=\"text-right\">\r\n                            <button \r\n                                type=\"button\"\r\n                                onClick={() => deleteTVA(tva.id)} \r\n                                className=\"btn btn-ghost btn-xs text-error\"\r\n                                title=\"Supprimer\"\r\n                            >\r\n                                <svg xmlns=\"http://www.w3.org/2000/svg\" className=\"h-4 w-4\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\r\n                                  <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth=\"2\" d=\"M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16\" />\r\n                                </svg>\r\n                            </button>\r\n                          </td>\r\n                        </tr>\r\n                      ))\r\n                    )}\r\n                  </tbody>\r\n                </table>\r\n              </div>\r\n\r\n              <div className=\"bg-base-100 p-4 rounded-lg border border-base-200\">\r\n                  <h3 className=\"font-medium mb-3 text-sm\">Ajouter un nouveau taux</h3>\r\n                  <div className=\"flex flex-col sm:flex-row gap-3 items-end\">\r\n                      <div className=\"form-control w-full sm:w-1/3\">\r\n                          <label className=\"label py-0 mb-1\"><span className=\"label-text-alt\">Taux (%) *</span></label>\r\n                          <input \r\n                              type=\"number\" \r\n                              step=\"0.01\" \r\n                              placeholder=\"19.25\" \r\n                              className=\"input input-bordered input-sm w-full\" \r\n                              value={newTvaRate}\r\n                              onChange={e => setNewTvaRate(e.target.value)}\r\n                          />\r\n                      </div>\r\n                      <div className=\"form-control w-full sm:w-1/2\">\r\n                          <label className=\"label py-0 mb-1\"><span className=\"label-text-alt\">Libell├® (Optionnel)</span></label>\r\n                          <input \r\n                              type=\"text\" \r\n                              placeholder=\"Ex: Taux Normal\" \r\n                              className=\"input input-bordered input-sm w-full\"\r\n                              value={newTvaLabel}\r\n                              onChange={e => setNewTvaLabel(e.target.value)}\r\n                          />\r\n                      </div>\r\n                      <button \r\n                          type=\"button\" \r\n                          className=\"btn btn-primary btn-sm\"\r\n                          onClick={handleAddTva}\r\n                          disabled={addingTva || !newTvaRate}\r\n                      >\r\n                          {addingTva ? <span className=\"loading loading-spinner loading-xs\"></span> : 'Ajouter'}\r\n                      </button>\r\n                  </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n\r\n          {/* Section: Configuration Commandes */}\r\n          <div className=\"bg-white rounded-xl shadow-sm border border-base-200 overflow-hidden\">\r\n            <div className=\"bg-base-100 px-6 py-4 border-b border-base-200\">\r\n              <h2 className=\"font-semibold text-lg flex items-center gap-2\">\r\n                <svg xmlns=\"http://www.w3.org/2000/svg\" className=\"h-5 w-5 text-primary\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\r\n                  <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth=\"2\" d=\"M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z\" />\r\n                </svg>\r\n                Configuration Commandes\r\n              </h2>\r\n            </div>\r\n            <div className=\"p-6 space-y-4\">\r\n              <div className=\"form-control\">\r\n                <label className=\"label\">\r\n                  <span className=\"label-text font-medium\">Coefficient Commandes Directes (Euro)</span>\r\n                </label>\r\n                <input\r\n                  type=\"number\"\r\n                  step=\"0.01\"\r\n                  min=\"1\"\r\n                  value={formData.coefficient_direct_commande || ''}\r\n                  onChange={(e) => handleChange('coefficient_direct_commande', e.target.value)}\r\n                  className=\"input input-bordered w-full\"\r\n                  placeholder=\"1.35\"\r\n                />\r\n                <label className=\"label\">\r\n                  <span className=\"label-text-alt text-base-content/50\">\r\n                    Ce coefficient sera utilis├® par d├®faut pour convertir le Prix d'achat (Euro) en Prix de Revient (FCFA).\r\n                    <br/>\r\n                    Formule: Prix Revient = (Prix Ôé¼ x Taux Change) x Coefficient\r\n                  </span>\r\n                </label>\r\n              </div>\r\n            </div>\r\n          </div>\r\n\r\n          {/* Mobile Submit Button */}\r\n          {/* Section: WhatsApp Business API */}\r\n          <div className=\"bg-white rounded-xl shadow-sm border border-base-200 overflow-hidden\">\r\n            <div className=\"bg-base-100 px-6 py-4 border-b border-base-200 flex items-center justify-between\">\r\n              <h2 className=\"font-semibold text-lg flex items-center gap-2\">\r\n                <svg xmlns=\"http://www.w3.org/2000/svg\" className=\"h-5 w-5 text-[#25D366]\" fill=\"currentColor\" viewBox=\"0 0 448 512\">\r\n                  <path d=\"M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 54 81.2 54 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-5.5-2.8-23.4-8.6-44.4-27.4-16.4-14.6-27.4-32.7-30.6-38.2-3.2-5.6-.3-8.6 2.5-11.3 2.5-2.4 5.5-6.5 8.3-9.7 2.8-3.3 3.7-5.6 5.5-9.3 1.9-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4